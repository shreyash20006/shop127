<!doctype html>
<html class="dark no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0A0A0A">
    <link rel="canonical" href="{{ canonical_url }}">
    
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% comment %} Open Graph / Facebook {% endcomment %}
    <meta property="og:site_name" content="{{ shop.name }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:title" content="{{ page_title }}">
    <meta property="og:type" content="website">
    {% if page_description %}
      <meta property="og:description" content="{{ page_description | escape }}">
    {% endif %}
    {%- if page_image -%}
      <meta property="og:image" content="http:{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="630">
    {%- endif -%}

    {% comment %} Twitter {% endcomment %}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ page_title }}">
    {% if page_description %}
      <meta name="twitter:description" content="{{ page_description | escape }}">
    {% endif %}
    {%- if page_image -%}
      <meta name="twitter:image" content="https:{{ page_image | image_url: width: 1200 }}">
    {%- endif -%}

    {% comment %} Fonts & Tailwind CDN {% endcomment %}
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "surface-container-low": "#1c1b1b",
                    "outline": "#8e9192",
                    "on-tertiary-fixed-variant": "#930005",
                    "surface": "#131313",
                    "secondary-fixed-dim": "#c8c6c5",
                    "primary": "#ffffff",
                    "surface-dim": "#131313",
                    "on-secondary": "#313030",
                    "on-tertiary": "#690003",
                    "on-error": "#690005",
                    "tertiary-fixed-dim": "#ffb4aa",
                    "tertiary-container": "#ffdad5",
                    "tertiary": "#ffffff",
                    "ink-muted": "#888888",
                    "surface-container-highest": "#353534",
                    "surface-tint": "#c6c6c7",
                    "alert-drop": "#FF3B30",
                    "inverse-surface": "#e5e2e1",
                    "surface-bright": "#3a3939",
                    "error": "#ffb4ab",
                    "surface-accent": "#1A1A1A",
                    "primary-fixed-dim": "#c6c6c7",
                    "primary-container": "#e2e2e2",
                    "surface-container-lowest": "#0e0e0e",
                    "inverse-primary": "#5d5f5f",
                    "on-primary-container": "#636565",
                    "on-primary-fixed": "#1a1c1c",
                    "on-primary": "#2f3131",
                    "on-tertiary-fixed": "#410001",
                    "on-surface-variant": "#c4c7c8",
                    "inverse-on-surface": "#313030",
                    "surface-container-high": "#2a2a2a",
                    "on-primary-fixed-variant": "#454747",
                    "on-secondary-fixed": "#1c1b1b",
                    "on-secondary-fixed-variant": "#474746",
                    "outline-variant": "#444748",
                    "surface-variant": "#353534",
                    "error-container": "#93000a",
                    "primary-fixed": "#e2e2e2",
                    "tertiary-fixed": "#ffdad5",
                    "surface-container": "#201f1f",
                    "secondary-fixed": "#e5e2e1",
                    "on-secondary-container": "#b7b5b4",
                    "secondary": "#c8c6c5",
                    "surface-elevated": "#111111",
                    "background": "#131313",
                    "secondary-container": "#474746",
                    "on-background": "#e5e2e1",
                    "on-error-container": "#ffdad6",
                    "on-tertiary-container": "#ca0a0f",
                    "on-surface": "#e5e2e1"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "spacing": {
                    "margin-mobile": "20px",
                    "gutter": "24px",
                    "margin-desktop": "64px",
                    "unit": "4px",
                    "container-max": "1440px"
            },
            "fontFamily": {
                    "headline-lg-mobile": ["Bebas Neue"],
                    "label-lg": ["Inter"],
                    "body-md": ["Inter"],
                    "price-display": ["Inter"],
                    "headline-md": ["Bebas Neue"],
                    "body-lg": ["Inter"],
                    "title-lg": ["Inter"],
                    "headline-lg": ["Bebas Neue"],
                    "display-lg": ["Bebas Neue"]
            },
            "fontSize": {
                    "headline-lg-mobile": ["36px", {"lineHeight": "36px", "fontWeight": "400"}],
                    "label-lg": ["14px", {"lineHeight": "20px", "letterSpacing": "0.05em", "fontWeight": "600"}],
                    "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                    "price-display": ["24px", {"lineHeight": "24px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                    "headline-md": ["32px", {"lineHeight": "32px", "fontWeight": "400"}],
                    "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}],
                    "title-lg": ["20px", {"lineHeight": "28px", "fontWeight": "700"}],
                    "headline-lg": ["48px", {"lineHeight": "48px", "letterSpacing": "0.02em", "fontWeight": "400"}],
                    "display-lg": ["72px", {"lineHeight": "72px", "letterSpacing": "0.02em", "fontWeight": "400"}]
            }
          },
        },
      }
    </script>
    <style>
        body { @apply bg-background text-on-background font-body-md; scroll-behavior: smooth; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .aspect-3-4 { aspect-ratio: 3 / 4; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>

    {% comment %} Critical Styles {% endcomment %}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ 'animations.css' | asset_url | stylesheet_tag }}

    {% comment %} Shopify Head hook {% endcomment %}
    {{ content_for_header }}

    {% comment %} Global JSON-LD Schema {% endcomment %}
    <script type="application/ld+json">
      {
        "@context": "http://schema.org",
        "@type": "Organization",
        "name": "{{ shop.name }}",
        "url": "{{ shop.url }}",
        "logo": "https://res.cloudinary.com/dsqxboxoc/image/upload/q_auto/f_auto/v1780928834/639473422_17856452319665295_1281961209085143497_n_mmtgqs.jpg",
        "sameAs": [
          "{{ settings.social_instagram_link }}",
          "{{ settings.social_facebook_link }}",
          "{{ settings.social_twitter_link }}"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+91 8261094774",
          "contactType": "customer service",
          "areaServed": "IN"
        }
      }
    </script>

    {%- if request.page_type == 'product' -%}
      <script type="application/ld+json">
        {
          "@context": "http://schema.org",
          "@type": "Product",
          "name": "{{ product.title | escape }}",
          "url": "{{ shop.url }}{{ product.url }}",
          "image": [
            {%- for image in product.images -%}
              "https:{{ image | image_url: width: 1200 }}"{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ],
          "description": "{{ product.description | strip_html | strip_newlines | escape }}",
          "brand": {
            "@type": "Brand",
            "name": "{{ shop.name }}"
          },
          "offers": {
            "@type": "AggregateOffer",
            "priceCurrency": "{{ cart.currency.iso_code }}",
            "lowPrice": "{{ product.price_min | money_without_currency | replace: ',', '' }}",
            "highPrice": "{{ product.price_max | money_without_currency | replace: ',', '' }}",
            "offerCount": "{{ product.variants.size }}",
            "offers": [
              {%- for variant in product.variants -%}
                {
                  "@type": "Offer",
                  "price": "{{ variant.price | money_without_currency | replace: ',', '' }}",
                  "priceCurrency": "{{ cart.currency.iso_code }}",
                  "availability": "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
                  "url": "{{ shop.url }}{{ variant.url }}"
                }{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ]
          }
        }
      </script>
    {%- endif -%}

    {%- if request.page_type == 'index' or request.page_type == 'collection' or request.page_type == 'product' -%}
      <script type="application/ld+json">
        {
          "@context": "http://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "{{ shop.url }}"
            }
            {%- if request.page_type == 'collection' -%}
              ,{
                "@type": "ListItem",
                "position": 2,
                "name": "{{ collection.title | escape }}",
                "item": "{{ shop.url }}{{ collection.url }}"
              }
            {%- elsif request.page_type == 'product' -%}
              {%- if collection -%}
                ,{
                  "@type": "ListItem",
                  "position": 2,
                  "name": "{{ collection.title | escape }}",
                  "item": "{{ shop.url }}{{ collection.url }}"
                }
                ,{
                  "@type": "ListItem",
                  "position": 3,
                  "name": "{{ product.title | escape }}",
                  "item": "{{ shop.url }}{{ product.url }}"
                }
              {%- else -%}
                ,{
                  "@type": "ListItem",
                  "position": 2,
                  "name": "{{ product.title | escape }}",
                  "item": "{{ shop.url }}{{ product.url }}"
                }
              {%- endif -%}
            {%- endif -%}
          ]
        }
      </script>
    {%- endif -%}

    {% comment %} Growave & App Hooks {% endcomment %}
    <script>
      window.shopUrl = '{{ request.origin }}';
      window.themeSettings = {
        freeShippingThreshold: 99900,
        currencySymbol: '₹',
        enableAnimations: {{ settings.enable_animations | default: true }}
      };
    </script>
  </head>

  <body class="template-{{ request.page_type | handle }} dark-theme">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      Skip to content
    </a>

    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    {% comment %} Cart Drawer component {% endcomment %}
    {% section 'cart-drawer' %}

    {% comment %} Floating WhatsApp Widget {% endcomment %}
    {% render 'whatsapp-button' %}

    {% comment %} Theme Global Scripts {% endcomment %}
    {{ 'theme.js' | asset_url | script_tag }}
    {{ 'header.js' | asset_url | script_tag }}
    {{ 'cart-drawer.js' | asset_url | script_tag }}
    
    {%- if request.page_type == 'product' -%}
      {{ 'product-page.js' | asset_url | script_tag }}
    {%- endif -%}

    {% comment %} App Integrations Hook {% endcomment %}
    {% comment %} Judge.me snippet hook {% endcomment %}
    {%- capture judgeme_widgets -%}
      {% render 'judge-me-product-review-widget' %}
    {%- endcapture -%}
    {%- unless judgeme_widgets contains "Error" -%}
      {{ judgeme_widgets }}
    {%- endunless -%}
  </body>
</html>
