{% comment %}
   Escape Clothing - Hero Banner Section (Redesigned with Tailwind CSS)
{% endcomment %}

<section class="relative h-screen w-full flex items-center justify-center overflow-hidden" id="HeroBanner-{{ section.id }}">
  <div class="absolute inset-0 bg-black/40 z-10"></div>
  
  {% comment %} Hero Background Image {% endcomment %}
  {%- if section.settings.image != blank -%}
    <img src="{{ section.settings.image | image_url: width: 2000 }}" 
         alt="{{ section.settings.heading }}" 
         class="absolute inset-0 w-full h-full object-cover">
  {%- else -%}
    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuD8R5LYV1JGkwb0p2Ps0GNmnPatXJ46b5XNJUuqkO4rNiLHXeo7lSVBHrMQvCOksNjLzQif0AJOntAsNieezNo5Ltn--3JYFUUVUBGHJ1-UBB1Zzh6ih-ffObJO2vv4JQ36S4iAuiqsU4ulpeu6EWJXfQdzetEmlx0FGyIDPVde-n9RqMAtIK2kJ9BmtgANgzxsVjYtdtrRVf3InpjsPN2kerIRUtnDUGhJ2Qp5hLQ-KxHQkNsK71Oda0vNg4QDootU4nW1Egxvqb4" 
         alt="Hero Background" 
         class="absolute inset-0 w-full h-full object-cover"
         data-alt="A cinematic wide shot of a dark, urban streetwear environment featuring a high-contrast aesthetic.">
  {%- endif -%}

  {% comment %} Hero Video URL (if configured) {% endcomment %}
  {%- if section.settings.video_url != blank -%}
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover z-0">
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {%- endif -%}

  <div class="relative z-20 text-center px-4 max-w-4xl">
    <span class="inline-block font-label-lg text-label-lg tracking-widest text-alert-drop mb-4 uppercase">
      {{ section.settings.tagline | default: "NEW COLLECTION" }}
    </span>
    <h1 class="font-display-lg text-7xl md:text-9xl text-primary uppercase leading-none mb-8 tracking-tighter">
      {{ section.settings.heading | default: "ESCAPE THE ORDINARY" }}
    </h1>
    
    {%- if section.settings.subheading != blank -%}
      <p class="font-body-lg text-lg md:text-2xl text-on-secondary-container mb-8 max-w-2xl mx-auto">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    <div class="flex flex-col md:flex-row gap-4 justify-center">
      <a href="{{ section.settings.btn_1_link | default: '/collections/all' }}" 
         class="bg-primary text-on-primary px-10 py-4 font-label-lg text-label-lg uppercase tracking-wider hover:opacity-90 transition-all active:scale-95 rounded-sm inline-block">
        {{ section.settings.btn_1_text | default: "SHOP NOW" }}
      </a>
      <a href="{{ section.settings.btn_2_link | default: '/collections/new-arrivals' }}" 
         class="bg-transparent border border-primary text-primary px-10 py-4 font-label-lg text-label-lg uppercase tracking-wider hover:bg-primary/10 transition-all active:scale-95 rounded-sm inline-block">
        {{ section.settings.btn_2_text | default: "NEW ARRIVALS" }}
      </a>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce">
    <span class="material-symbols-outlined text-primary text-3xl">expand_more</span>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Background Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Hero Video MP4 Direct Link (Optional)"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline Text",
      "default": "NEW COLLECTION"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading Text",
      "default": "ESCAPE THE ORDINARY"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading Text"
    },
    {
      "type": "text",
      "id": "btn_1_text",
      "label": "Primary Button Title",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "btn_1_link",
      "label": "Primary Button Destination"
    },
    {
      "type": "text",
      "id": "btn_2_text",
      "label": "Secondary Button Title",
      "default": "NEW ARRIVALS"
    },
    {
      "type": "url",
      "id": "btn_2_link",
      "label": "Secondary Button Destination"
    }
  ]
}
{% endschema %}
