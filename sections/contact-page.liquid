{% comment %}
   Escape Clothing - Contact Page Section
{% endcomment %}

<section class="contact-page-section reveal" id="ContactPage-{{ section.id }}">
  <div class="container grid contact-page-inner" style="max-width: 1100px; padding: 120px 24px 80px 24px;">
    
    {% comment %} Left side: Store details {% endcomment %}
    <div class="contact-details-wrap">
      <h1 class="section-title" style="font-size: 5.6rem; margin-bottom: 24px;">CONTACT US</h1>
      <p style="font-size: 1.6rem; color: var(--text-secondary); line-height: 1.8; margin-bottom: 40px;">
        Got questions about a drop, size fits, or orders? Hit us up. Our customer support crew is active Monday to Saturday, 10 AM to 7 PM.
      </p>

      <div class="contact-info-blocks flex flex-column" style="gap: 32px;">
        
        <div class="info-block flex">
          <div class="info-block__icon">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <div>
            <h4 style="font-size: 1.6rem; font-weight: 700; margin-bottom: 6px;">CALL OR WHATSAPP</h4>
            <p style="font-size: 1.4rem; color: var(--text-muted);"><a href="https://wa.me/918261094774">+91 8261094774</a></p>
          </div>
        </div>

        <div class="info-block flex">
          <div class="info-block__icon">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </div>
          <div>
            <h4 style="font-size: 1.6rem; font-weight: 700; margin-bottom: 6px;">EMAIL SUPPORT</h4>
            <p style="font-size: 1.4rem; color: var(--text-muted);"><a href="mailto:support@escapeclothing.in">support@escapeclothing.in</a></p>
          </div>
        </div>

        <div class="info-block flex">
          <div class="info-block__icon">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <div>
            <h4 style="font-size: 1.6rem; font-weight: 700; margin-bottom: 6px;">HEADQUARTERS</h4>
            <p style="font-size: 1.4rem; color: var(--text-muted); line-height: 1.5;">Nagpur, Maharashtra, India</p>
          </div>
        </div>

      </div>
    </div>

    {% comment %} Right side: Contact form {% endcomment %}
    <div class="contact-form-wrap" style="background-color: var(--surface-primary); border: 1px solid var(--border-color); padding: 40px; border-radius: var(--border-radius);">
      {%- form 'contact', class: 'flex flex-column', style: 'gap: 20px;' -%}
        
        {%- if form.posted_successfully? -%}
          <div class="newsletter-success-msg text-center">
            <svg class="success-icon" viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2.5" fill="none"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <p>Message sent successfully! We will get back to you shortly.</p>
          </div>
        {%- else -%}
          
          <div class="flex flex-column" style="gap: 8px;">
            <label for="ContactFormName" style="font-size: 1.2rem; font-weight: 700; color: var(--text-muted);">NAME</label>
            <input type="text" id="ContactFormName" name="contact[name]" class="form-input" placeholder="YOUR NAME" required>
          </div>

          <div class="flex flex-column" style="gap: 8px;">
            <label for="ContactFormEmail" style="font-size: 1.2rem; font-weight: 700; color: var(--text-muted);">EMAIL</label>
            <input type="email" id="ContactFormEmail" name="contact[email]" class="form-input" placeholder="YOUR EMAIL" required>
          </div>

          <div class="flex flex-column" style="gap: 8px;">
            <label for="ContactFormPhone" style="font-size: 1.2rem; font-weight: 700; color: var(--text-muted);">PHONE</label>
            <input type="tel" id="ContactFormPhone" name="contact[phone]" class="form-input" placeholder="YOUR PHONE NUMBER">
          </div>

          <div class="flex flex-column" style="gap: 8px;">
            <label for="ContactFormMessage" style="font-size: 1.2rem; font-weight: 700; color: var(--text-muted);">MESSAGE</label>
            <textarea id="ContactFormMessage" name="contact[body]" rows="5" class="form-input" placeholder="HOW CAN WE HELP?" required style="resize: none;"></textarea>
          </div>

          <div style="margin-top: 12px;">
            <button type="submit" class="btn btn-primary btn-hover-slide" style="width: 100%;">SEND MESSAGE</button>
          </div>

        {%- endif -%}
      {%- endform -%}
    </div>

  </div>
</section>

<style>
  .contact-page-section {
    background-color: var(--bg-color);
  }
  .contact-page-inner {
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }
  .info-block {
    gap: 16px;
    align-items: flex-start;
  }
  .info-block__icon {
    color: var(--highlight-color);
    margin-top: 2px;
  }

  @media screen and (min-width: 768px) {
    .contact-page-inner {
      grid-template-columns: 1fr 1.2fr;
      gap: 64px;
    }
  }
</style>

{% schema %}
{
  "name": "Contact Page",
  "settings": []
}
{% endschema %}
