{% comment %}
   Escape Clothing - Customer Login Page (OS 2.0)
{% endcomment %}

<section class="py-24 bg-surface text-primary min-h-[70vh] flex items-center" id="CustomerLogin-{{ section.id }}">
  <div class="px-margin-mobile w-full max-w-md mx-auto">
    
    <!-- Sign In Panel -->
    <div id="login-panel" class="space-y-8">
      <div class="text-center">
        <h1 class="font-display-lg text-5xl uppercase tracking-tighter">LOG IN</h1>
        <p class="font-label-lg text-xs text-outline mt-2 uppercase tracking-widest">ENTER YOUR ACCOUNT TO JOIN THE CULT</p>
      </div>

      {%- form 'customer_login', class: 'space-y-6' -%}
        {{ form.errors | default_errors }}

        <div class="space-y-2">
          <label for="CustomerEmail" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Email Address</label>
          <input type="email" 
                 name="customer[email]" 
                 id="CustomerEmail" 
                 autocomplete="email" 
                 autocorrect="off" 
                 autocapitalize="off" 
                 required
                 class="w-full bg-surface-accent border border-outline-variant p-4 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
        </div>

        {%- if form.password_needed -%}
          <div class="space-y-2">
            <div class="flex justify-between items-center">
              <label for="CustomerPassword" class="font-label-lg text-xs text-outline uppercase tracking-wider">Password</label>
              <a href="#recover" onclick="toggleForm('recover')" class="font-label-lg text-xs text-outline hover:text-primary transition-colors uppercase tracking-wider underline">Forgot?</a>
            </div>
            <input type="password" 
                   name="customer[password]" 
                   id="CustomerPassword" 
                   autocomplete="current-password" 
                   required
                   class="w-full bg-surface-accent border border-outline-variant p-4 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
          </div>
        {%- endif -%}

        <div class="pt-4 space-y-4">
          <button type="submit" class="w-full bg-primary text-on-primary py-4 font-label-lg text-label-lg uppercase tracking-widest hover:opacity-90 transition-all active:scale-95">
            SIGN IN
          </button>
          
          <p class="text-center font-body-md text-sm text-outline">
            Don't have an account? 
            <a href="{{ routes.account_register_url }}" class="text-primary font-semibold underline hover:text-outline transition-colors">Create one</a>
          </p>
        </div>
      {%- endform -%}
    </div>

    <!-- Password Recovery Panel -->
    <div id="recover-panel" class="hidden space-y-8">
      <div class="text-center">
        <h2 class="font-display-lg text-5xl uppercase tracking-tighter">RESET PASSWORD</h2>
        <p class="font-label-lg text-xs text-outline mt-2 uppercase tracking-widest">WE WILL SEND YOU AN EMAIL TO RESET PASSWORD</p>
      </div>

      {%- form 'recover_customer_password', class: 'space-y-6' -%}
        {%- if form.posted_successfully? -%}
          <div class="bg-green-500/10 border border-green-500/30 text-green-500 p-4 text-sm font-semibold tracking-wide uppercase text-center">
            RESET EMAIL SENT SUCCESSFULLY!
          </div>
        {%- endif -%}

        <div class="space-y-2">
          <label for="RecoverEmail" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Email Address</label>
          <input type="email" 
                 name="email" 
                 id="RecoverEmail" 
                 autocomplete="email" 
                 autocorrect="off" 
                 autocapitalize="off" 
                 required
                 class="w-full bg-surface-accent border border-outline-variant p-4 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
        </div>

        <div class="pt-4 space-y-4">
          <button type="submit" class="w-full bg-primary text-on-primary py-4 font-label-lg text-label-lg uppercase tracking-widest hover:opacity-90 transition-all active:scale-95">
            SUBMIT
          </button>
          
          <button type="button" onclick="toggleForm('login')" class="w-full bg-transparent border border-outline hover:border-primary text-primary py-4 font-label-lg text-xs uppercase tracking-widest transition-all">
            CANCEL
          </button>
        </div>
      {%- endform -%}
    </div>

  </div>
</section>

<script>
  function toggleForm(formType) {
    const loginPanel = document.getElementById('login-panel');
    const recoverPanel = document.getElementById('recover-panel');
    if (formType === 'recover') {
      loginPanel.classList.add('hidden');
      recoverPanel.classList.remove('hidden');
    } else {
      loginPanel.classList.remove('hidden');
      recoverPanel.classList.add('hidden');
    }
  }

  // Auto show recover if hash is present
  if (window.location.hash === '#recover') {
    toggleForm('recover');
  }
</script>
