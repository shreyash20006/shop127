{% comment %}
   Escape Clothing - Featured Categories Section
{% endcomment %}

<section class="featured-categories-section reveal" id="FeaturedCategories-{{ section.id }}">
  <div class="container">
    
    <div class="section-header">
      <h2 class="section-title has-line">{{ section.settings.title | default: "SHOP BY CATEGORY" }}</h2>
    </div>

    <div class="categories-grid flex mobile-scroll-container">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.collection_link | default: '/collections/all' }}" class="category-card" {{ block.shopify_attributes }}>
          <div class="category-card__image-wrap">
            {%- if block.settings.image != blank -%}
              <img class="category-card__image" 
                   src="{{ block.settings.image | image_url: width: 600 }}" 
                   alt="{{ block.settings.title }}" 
                   loading="lazy">
            {%- else -%}
              {% comment %} Fallback beautiful Unsplash streetwear assets {% endcomment %}
              {%- capture placeholder_url -%}
                {%- case forloop.index -%}
                  {%- when 1 -%} https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=600&auto=format&fit=crop
                  {%- when 2 -%} https://images.unsplash.com/photo-1521572267360-ee0c2909d518?q=80&w=600&auto=format&fit=crop
                  {%- when 3 -%} https://images.unsplash.com/photo-1618354691373-d851c5c3a990?q=80&w=600&auto=format&fit=crop
                  {%- when 4 -%} https://images.unsplash.com/photo-1506152983158-b4a74a01c721?q=80&w=600&auto=format&fit=crop
                  {%- else -%} https://images.unsplash.com/photo-1556821840-3a63f95609a7?q=80&w=600&auto=format&fit=crop
                {%- endcase -%}
              {%- endcapture -%}
              <img class="category-card__image" 
                   src="{{ placeholder_url | strip }}" 
                   alt="{{ block.settings.title }}" 
                   loading="lazy">
            {%- endif -%}
            
            <div class="category-card__overlay"></div>
            
            <div class="category-card__content">
              <h3 class="category-card__title">{{ block.settings.title }}</h3>
              <span class="category-card__explore">Explore &rarr;</span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  .featured-categories-section {
    padding: 80px 0;
    background-color: var(--bg-color);
  }
  .categories-grid {
    gap: 16px;
    width: 100%;
  }
  .category-card {
    flex: 0 0 260px; /* layout for horizontal scroll */
    aspect-ratio: 3/4;
    position: relative;
    overflow: hidden;
    border-radius: var(--border-radius);
    border: 1px solid var(--border-color);
  }
  .category-card__image-wrap {
    width: 100%;
    height: 100%;
    position: relative;
  }
  .category-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  .category-card__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 60%, rgba(0,0,0,0) 100%);
    transition: var(--transition-smooth);
    z-index: 1;
  }
  .category-card__content {
    position: absolute;
    bottom: 24px;
    left: 24px;
    right: 24px;
    z-index: 2;
  }
  .category-card__title {
    font-size: 2.8rem;
    color: #FFFFFF;
    margin-bottom: 8px;
    letter-spacing: 1px;
    transition: var(--transition-smooth);
  }
  .category-card__explore {
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--highlight-color);
    display: inline-block;
    transform: translateY(15px);
    opacity: 0;
    transition: var(--transition-smooth);
  }

  /* Hover Animations */
  .category-card:hover .category-card__image {
    transform: scale(1.05);
  }
  .category-card:hover .category-card__overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.1) 60%, rgba(0,0,0,0) 100%);
  }
  .category-card:hover .category-card__explore {
    transform: translateY(0);
    opacity: 1;
  }

  /* Horizontal Scroll behavior on Mobile */
  @media screen and (max-width: 989px) {
    .mobile-scroll-container {
      overflow-x: auto;
      padding-bottom: 15px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }
    .category-card {
      scroll-snap-align: start;
    }
  }

  @media screen and (min-width: 990px) {
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
    }
    .category-card {
      flex: none;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Categories",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading Text",
      "default": "SHOP BY CATEGORY"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Oversized Tees"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "url",
          "id": "collection_link",
          "label": "Collection Destination Link"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "category",
        "settings": { "title": "Jerseys" }
      },
      {
        "type": "category",
        "settings": { "title": "Oversized Tees" }
      },
      {
        "type": "category",
        "settings": { "title": "Shirts" }
      },
      {
        "type": "category",
        "settings": { "title": "Bottoms" }
      },
      {
        "type": "category",
        "settings": { "title": "₹999 Drop" }
      }
    ]
  }
}
{% endschema %}
