{% comment %}
   Escape Clothing - Featured Categories Section (Redesigned with Tailwind CSS)
{% endcomment %}

<section class="py-24 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto" id="FeaturedCategories-{{ section.id }}">
  <div class="mb-12">
    <h2 class="font-headline-lg text-headline-lg uppercase text-primary">{{ section.settings.title | default: "CATEGORIES" }}</h2>
  </div>
  
  <div class="grid grid-cols-2 md:grid-cols-5 gap-gutter">
    {%- for block in section.blocks -%}
      {%- assign is_promo = false -%}
      {%- if forloop.index == 5 or block.settings.title contains '999' -%}
        {%- assign is_promo = true -%}
      {%- endif -%}

      <a class="group relative overflow-hidden aspect-3-4 bg-surface-container {% if is_promo %}col-span-2 md:col-span-1{% endif %}" 
         href="{{ block.settings.collection_link | default: '/collections/all' }}" 
         {{ block.shopify_attributes }}>
        
        {%- if block.settings.image != blank -%}
          <img class="w-full h-full object-cover {% unless is_promo %}grayscale transition-all duration-700 group-hover:scale-110 group-hover:grayscale-0{% else %}transition-all duration-700 group-hover:scale-110{% endunless %}" 
               src="{{ block.settings.image | image_url: width: 600 }}" 
               alt="{{ block.settings.title }}" 
               loading="lazy">
        {%- else -%}
          {% comment %} Fallback images matching mockup {% endcomment %}
          {%- capture placeholder_url -%}
            {%- case forloop.index -%}
              {%- when 1 -%} https://lh3.googleusercontent.com/aida-public/AB6AXuBmJ7k5ufWGBOcEhXOQt6_6iRH706PmLCDufd7zAqwBhTaqYk4Bmyrv4O982Bt2WV0my-GrUgvZJ6ZzUAx75VQhsuWy0nPQMXE76p7C9EebMgSigiyD6fyRFKwoJV75wyXNFPeIJYmQ-HklhRc0eL5aKOHLyJkBbMVwXvcBjj5FB7Moc8FQgyotINpMqRVUADWlLLZ_6RGBGfL4vOr1jZJqxYdvuTApp4uedkg9znnVh35XnAN4Lpm5dlTDXKTVt97C_KyRcYS7XJw
              {%- when 2 -%} https://lh3.googleusercontent.com/aida-public/AB6AXuCUkk2GmPLID1uow4zfjEjPxmIk_uEYFrCM_agkhnGxcuLIsmsIz2qLEpGRD7E7Er4hi4JEKBV6Eh3gcYa4CVH_QOOch9nh6cM9pzsIcOHsyGgQH6vZOWUUpKRhV2BA_Y8Hj6anGf2Ht58g4M7IRYQB7AB-AKrxQv3AEt0FalvOv2auf8UsFl-VS6lYuLCYLaFhuzOWIpjYEuaOSt3lJNgicpkWPZ2LMnvEhMO525bnIu53Ph_m43tNI6XNfg5zyc5ayyiIxrchJ8o
              {%- when 3 -%} https://lh3.googleusercontent.com/aida-public/AB6AXuASmFt1-pjZxSMKSWuq7X5E2FTVOSDNbJ2E0Wsxv1w4XoZjaZ03zqjEvWixzbO_mvBjGE9VSHKXnq-0KprOe5yOyAKzd1QvoBo3iA3ZFaf7h4o1hoJaD2_YwqTloAszMkaPvlRSrCL5cIEqiO0nsdg3O-uYTQPrM1CYXkukH0cNrOHYa4fTTrGs1zf--y_qSYHkNXTCxLpmeFi7FKCUcX72Dm9Vj2tMINOup_b9SO4hLbWPAPlMZqHks4ouVQEfTCnppLDhCPS4AhA
              {%- when 4 -%} https://lh3.googleusercontent.com/aida-public/AB6AXuAzzBVxXu6ekmnDekc4vF3nsa-sCkYJakL5KEVdc7sYOyKzARV0XBqJMylWqt30IPhvWSWTWWD0XyUc7fCTSw7LuWMYdWiEouNzHn_7txoMqcLOz0Y4dPEyQJwjfTnt7x8VYsygynRvBI6pVX-Fz86VXgv_QN7GJqRwNLPrPKOU9SsINY-J6wkmmi-VOxVhHxNiJ1EREiIxcf70Ol3CKofYQndkNe3UXIW0nFc-9-PMx78AiJSKrd8RrWYMMuTvH-EELANnrQj-oSg
              {%- else -%} https://lh3.googleusercontent.com/aida-public/AB6AXuC2CTtDMaO-JJji-oaiie76s4vZzcRr3eYmtgx3O6pYpDuWUU9y8dg6Vf47L00a_8C89VbiNqS3mwgEHSPCRwZlAwYX2QfiFhzR-p3w2cXMl1V84c1MN78HJCgQUlH_I35Hips1hq2o6JZS3VyKzmvMVy7XztfIbVTDeOh4rZ_WgQQHApXvxWZ0N604GZZTniLlJdpVZAUqkASgGUJexFVcOf6gX1rM953l6_jC3he7GxjMdlpj1nwauq_B5t3dJeAoGN_MKzchF3k
            {%- endcase -%}
          {%- endcapture -%}
          <img class="w-full h-full object-cover {% unless is_promo %}grayscale transition-all duration-700 group-hover:scale-110 group-hover:grayscale-0{% else %}transition-all duration-700 group-hover:scale-110{% endunless %}" 
               src="{{ placeholder_url | strip }}" 
               alt="{{ block.settings.title }}" 
               loading="lazy">
        {%- endif -%}

        {%- if is_promo -%}
          <div class="absolute inset-0 bg-alert-drop/10 group-hover:bg-alert-drop/0 transition-colors"></div>
        {%- endif -%}

        <div class="absolute inset-0 bg-gradient-to-t {% if is_promo %}from-black/90{% else %}from-black/80{% endif %} via-transparent to-transparent"></div>
        
        <div class="absolute bottom-6 left-6">
          <p class="font-headline-md text-headline-md uppercase {% if is_promo %}text-alert-drop tracking-tight{% else %}text-primary{% endif %}">
            {{ block.settings.title }}
          </p>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Categories",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading Text",
      "default": "CATEGORIES"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Oversized Tees"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "url",
          "id": "collection_link",
          "label": "Collection Destination Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Categories",
      "category": "Collections"
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "category",
        "settings": { "title": "JERSEYS" }
      },
      {
        "type": "category",
        "settings": { "title": "OVERSIZED TEES" }
      },
      {
        "type": "category",
        "settings": { "title": "SHIRTS" }
      },
      {
        "type": "category",
        "settings": { "title": "BOTTOMS" }
      },
      {
        "type": "category",
        "settings": { "title": "₹999 DROP" }
      }
    ]
  }
}
{% endschema %}
