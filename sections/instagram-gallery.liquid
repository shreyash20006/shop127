{% schema %}
{
  "name": "Instagram Gallery",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "handle",
      "label": "Instagram Handle",
      "default": "@escape_clothing17"
    }
  ],
  "blocks": [
    {
      "type": "instagram_photo",
      "name": "Instagram Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Upload Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Gallery",
      "category": "Social Media"
    }
  ],
  "default": {
    "blocks": [
      { "type": "instagram_photo" },
      { "type": "instagram_photo" },
      { "type": "instagram_photo" },
      { "type": "instagram_photo" },
      { "type": "instagram_photo" },
      { "type": "instagram_photo" }
    ]
  }
}
{% endschema %}
