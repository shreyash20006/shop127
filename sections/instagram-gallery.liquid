{% comment %}
   Escape Clothing - Instagram Gallery Section (Redesigned with Tailwind CSS)
{% endcomment %}

<section class="py-24 bg-surface-container-lowest" id="InstagramGallery-{{ section.id }}">
  <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto text-center mb-12">
    <h2 class="font-headline-lg text-headline-lg text-primary uppercase">JOIN THE CULT</h2>
    <a class="font-label-lg text-label-lg text-outline hover:text-primary transition-colors" href="{{ settings.social_instagram_link | default: 'https://instagram.com/escape_clothing17' }}" target="_blank">
      {{ section.settings.handle | default: "@escape_clothing17" }}
    </a>
  </div>
  
  <div class="grid grid-cols-2 md:grid-cols-6">
    {%- for block in section.blocks limit: 6 -%}
      <div class="aspect-square overflow-hidden border border-background" {{ block.shopify_attributes }}>
        <a href="{{ settings.social_instagram_link | default: 'https://instagram.com/escape_clothing17' }}" target="_blank" class="block w-full h-full">
          {%- if block.settings.image != blank -%}
            <img class="w-full h-full object-cover hover:scale-110 transition-transform duration-700 grayscale hover:grayscale-0" 
                 src="{{ block.settings.image | image_url: width: 600, height: 600, crop: 'center' }}" 
                 alt="Instagram gallery image" 
                 loading="lazy">
