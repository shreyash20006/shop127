{% comment %}
   Escape Clothing - Instagram Gallery Section
{% endcomment %}

<section class="instagram-gallery-section reveal" id="InstagramGallery-{{ section.id }}">
  <div class="container">
    
    <div class="section-header text-center" style="display: block; margin-bottom: 32px;">
      <h2 class="section-title" style="font-size: 3.6rem; letter-spacing: 2px;">
        <a href="{{ settings.social_instagram_link | default: 'https://instagram.com/escape_clothing17' }}" target="_blank" style="color: var(--text-primary); border-bottom: 2px solid transparent;">
          {{ section.settings.handle | default: "@escape_clothing17" }}
        </a>
      </h2>
      <p style="font-size: 1.4rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 2px; margin-top: 8px;">TAG US TO GET FEATURED #ESCAPE</p>
    </div>

    <div class="instagram-grid grid">
      {%- for block in section.blocks limit: 6 -%}
        <a href="{{ settings.social_instagram_link | default: 'https://instagram.com/escape_clothing17' }}" target="_blank" class="instagram-item" {{ block.shopify_attributes }}>
          <div class="instagram-item__image-wrap">
            {%- if block.settings.image != blank -%}
              <img class="instagram-item__image" src="{{ block.settings.image | image_url: width: 600, height: 600, crop: 'center' }}" alt="Streetwear gallery image" loading="lazy">
            {%- else -%}
              {%- capture placeholder_url -%}
                {%- case forloop.index -%}
                  {%- when 1 -%} https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=600&auto=format&fit=crop
                  {%- when 2 -%} https://images.unsplash.com/photo-1529139574466-a303027c1d8b?q=80&w=600&auto=format&fit=crop
                  {%- when 3 -%} https://images.unsplash.com/photo-1483985988355-763728e1935b?q=80&w=600&auto=format&fit=crop
                  {%- when 4 -%} https://images.unsplash.com/photo-1539109136881-3be0616acf4b?q=80&w=600&auto=format&fit=crop
                  {%- when 5 -%} https://images.unsplash.com/photo-1509631179647-0177331693ae?q=80&w=600&auto=format&fit=crop
                  {%- else -%} https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?q=80&w=600&auto=format&fit=crop
                {%- endcase -%}
              {%- endcapture -%}
              <img class="instagram-item__image" src="{{ placeholder_url | strip }}" alt="Streetwear gallery placeholder" loading="lazy">
            {%- endif -%}
            
            {% comment %} Overlay displaying Instagram logo {% endcomment %}
            <div class="instagram-item__overlay flex align-center justify-center">
              <svg class="instagram-icon" viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="2" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>

    <div class="instagram-gallery-cta text-center" style="margin-top: 40px;">
      <a href="{{ settings.social_instagram_link | default: 'https://instagram.com/escape_clothing17' }}" target="_blank" class="view-all-link">FOLLOW US ON INSTAGRAM &rarr;</a>
    </div>

  </div>
</section>

<style>
  .instagram-gallery-section {
    padding: 80px 0;
    background-color: var(--bg-color);
  }
  .instagram-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .instagram-item {
    aspect-ratio: 1/1;
    overflow: hidden;
    position: relative;
    border-radius: var(--border-radius);
    border: 1px solid var(--border-color);
  }
  .instagram-item__image-wrap {
    width: 100%;
    height: 100%;
    position: relative;
  }
  .instagram-item__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  
  .instagram-item__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6);
    opacity: 0;
    z-index: 1;
    color: #FFFFFF;
    transition: opacity 0.3s ease;
  }
  
  .instagram-icon {
    transform: scale(0.8);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  /* Hover effects */
  .instagram-item:hover .instagram-item__image {
    transform: scale(1.06);
  }
  .instagram-item:hover .instagram-item__overlay {
    opacity: 1;
  }
  .instagram-item:hover .instagram-icon {
    transform: scale(1);
  }

  @media screen and (min-width: 768px) {
    .instagram-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
  }
  @media screen and (min-width: 990px) {
    .instagram-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Instagram Gallery",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "handle",
      "label": "Instagram Handle",
      "default": "@escape_clothing17"
    }
  ],
  "blocks": [
    {
      "type": "instagram_photo",
      "name": "Instagram Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Upload Image"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "instagram_photo" },
      { "type": "instagram_photo" },
      { "type": "instagram_photo" },
      { "type": "instagram_photo" },
      { "type": "instagram_photo" },
      { "type": "instagram_photo" }
    ]
  }
}
{% endschema %}
