{% comment %}
   Escape Clothing - Newsletter Section (Redesigned with Tailwind CSS)
{% endcomment %}

<section class="py-24 bg-surface border-t border-outline-variant" id="Newsletter-{{ section.id }}">
  <div class="px-margin-mobile md:px-margin-desktop max-w-2xl mx-auto text-center">
    <h2 class="font-headline-lg text-headline-lg text-primary uppercase mb-4">
      {{ section.settings.heading | default: "GET EARLY ACCESS TO DROPS" }}
    </h2>
    <p class="font-body-md text-outline mb-10">
      {{ section.settings.subtext | default: "Sign up to our newsletter and be the first to know about new arrivals and exclusive limited-time discounts." }}
    </p>

    {%- form 'customer', class: 'flex flex-col gap-4' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      
      {%- if form.posted_successfully? -%}
        <div class="bg-primary/10 border border-primary/30 p-4 text-primary font-label-lg uppercase">
          {{ section.settings.success_message | default: "Welcome to the Crew! Standby for early drops." }}
        </div>
      {%- else -%}
        <div class="flex flex-col md:flex-row gap-4">
          <input 
            type="email" 
            name="contact[email]" 
            id="NewsletterEmail-{{ section.id }}" 
            class="flex-1 bg-surface-accent border border-outline-variant p-4 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors" 
            value="{{ form.email }}" 
            placeholder="ENTER YOUR EMAIL" 
            autocorrect="off" 
            autocapitalize="off" 
            required
          >
          <button 
            type="submit" 
            class="bg-primary text-on-primary px-10 py-4 font-label-lg text-label-lg uppercase tracking-widest hover:opacity-90 transition-all active:scale-95" 
            name="commit" 
            id="SubscribeBtn-{{ section.id }}"
          >
            JOIN
          </button>
        </div>
        
        {%- if form.errors -%}
          <p class="text-sm mt-2 text-alert-drop">
            {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
          </p>
        {%- endif -%}
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter Signup",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "GET EARLY ACCESS TO DROPS"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext Info",
      "default": "Sign up to our newsletter and be the first to know about new arrivals and exclusive limited-time discounts."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Confirmation Text",
      "default": "Welcome to the Crew! Standby for early drops."
    }
  ],
  "presets": [
    {
      "name": "Newsletter",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
