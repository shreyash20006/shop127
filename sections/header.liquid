{% comment %}
   Escape Clothing - Main Site Header Section (Redesigned with Tailwind CSS)
{% endcomment %}

<header class="site-header fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-md dark:bg-surface/80 border-b border-surface-container-highest dark:border-outline-variant h-20 transition-all duration-300" role="banner">
  <nav class="flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop h-full max-w-container-max mx-auto">
    
    {% comment %} Left side: Brand Logo / Hamburger for mobile {% endcomment %}
    <div class="flex items-center gap-4 md:gap-8">
      <button class="md:hidden flex flex-col justify-between w-6 h-4 text-primary" id="MobileMenuToggle" aria-label="Open Navigation Menu">
        <span class="w-full h-[2px] bg-primary transition-all duration-300"></span>
        <span class="w-full h-[2px] bg-primary transition-all duration-300 my-[5px]"></span>
        <span class="w-full h-[2px] bg-primary transition-all duration-300"></span>
      </button>

      <a class="font-display-lg text-headline-lg uppercase tracking-tighter text-primary dark:text-primary flex items-center gap-2" href="/">
        {%- if section.settings.logo_upload != blank -%}
          <img src="{{ section.settings.logo_upload | image_url: width: 200 }}" 
               alt="{{ shop.name }}" 
               class="h-10 w-auto">
        {%- else -%}
          <img src="https://res.cloudinary.com/dsqxboxoc/image/upload/q_auto/f_auto/v1780928834/639473422_17856452319665295_1281961209085143497_n_mmtgqs.jpg" 
               alt="Escape Clothing" 
               class="h-10 w-auto">
        {%- endif -%}
        <span class="hidden lg:block">{{ shop.name }}</span>
      </a>
    </div>

    {% comment %} Center: Navigation Menu (Desktop) {% endcomment %}
    <div class="hidden md:flex items-center gap-8">
      {%- for link in section.settings.main_menu.links -%}
        <a class="font-label-lg text-label-lg {% if link.active %}text-primary border-b-2 border-primary pb-1{% else %}text-outline hover:text-primary transition-colors{% endif %}" href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    </div>

    {% comment %} Right side: Icon buttons {% endcomment %}
    <div class="flex items-center gap-4 md:gap-6">
      <a href="/search" class="hover:opacity-80 transition-opacity"><span class="material-symbols-outlined text-primary text-2xl">search</span></a>
      <a href="/account" class="hover:opacity-80 transition-opacity"><span class="material-symbols-outlined text-primary text-2xl">person</span></a>
      <a href="#wishlist" class="hover:opacity-80 transition-opacity"><span class="material-symbols-outlined text-primary text-2xl">favorite</span></a>
      <a href="/cart" class="hover:opacity-80 transition-opacity relative js-cart-trigger">
        <span class="material-symbols-outlined text-primary text-2xl">shopping_cart</span>
        <span class="absolute -top-1 -right-1 bg-alert-drop text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center cart-count-badge" {% if cart.item_count == 0 %}style="display:none;"{% endif %}>{{ cart.item_count }}</span>
      </a>
    </div>
  </nav>
</header>

{% comment %} Mobile Menu Slide-in Overlay {% endcomment %}
<div class="mobile-menu-overlay fixed inset-0 w-full h-full bg-black/60 z-[1001] opacity-0 pointer-events-none transition-opacity duration-300" id="MobileMenuOverlay">
  <div class="mobile-menu-inner w-4/5 max-w-sm h-full bg-surface-container px-6 py-8 transform -translate-x-full transition-transform duration-300 flex flex-col">
    <div class="flex justify-between items-center mb-10">
      <span class="font-display-lg text-headline-md tracking-widest">ESCAPE CLOTHING</span>
      <button class="text-3xl text-outline hover:text-primary" id="MobileMenuClose" aria-label="Close Navigation Menu">×</button>
    </div>
    
    <nav class="flex flex-col gap-6" role="navigation">
      {%- for link in section.settings.main_menu.links -%}
        <div class="mobile-nav__item opacity-0 transform -translate-x-4 transition-all duration-300">
          <a href="{{ link.url }}" class="font-display-lg text-3xl tracking-widest uppercase hover:text-primary {% if link.active %}text-alert-drop{% endif %}">{{ link.title }}</a>
        </div>
      {%- endfor -%}
      
      <div class="mobile-nav__item opacity-0 transform -translate-x-4 transition-all duration-300 h-[1px] bg-outline-variant my-4"></div>
      
      <div class="mobile-nav__item opacity-0 transform -translate-x-4 transition-all duration-300">
        <a href="/account" class="font-label-lg text-lg text-outline hover:text-primary uppercase">My Account</a>
      </div>
      <div class="mobile-nav__item opacity-0 transform -translate-x-4 transition-all duration-300">
        <a href="#wishlist" class="font-label-lg text-lg text-outline hover:text-primary uppercase">My Wishlist</a>
      </div>
    </nav>
  </div>
</div>

<style>
  /* Sticky header transition overrides */
  .site-header {
    transition: transform 0.3s ease, background-color 0.3s ease, border-color 0.3s ease;
  }
  .header-scrolled {
    background-color: rgba(19, 19, 19, 0.85) !important;
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-color);
  }
  .header-hidden {
    transform: translateY(-100%);
  }
  .mobile-menu-overlay.active {
    opacity: 1;
    pointer-events: all;
  }
  .mobile-menu-overlay.active .mobile-menu-inner {
    transform: translateX(0);
  }
  .mobile-menu-overlay.active .mobile-nav__item.visible {
    opacity: 1;
    transform: translateX(0);
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_upload",
      "label": "Upload Custom Logo"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "unit": "px",
      "label": "Logo Max Width",
      "default": 140
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Menu Link List",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
