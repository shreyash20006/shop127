{% comment %}
   Escape Clothing - Footer Section (Redesigned with Tailwind CSS)
{% endcomment %}

<footer class="bg-surface-container-lowest dark:bg-surface-container-lowest border-t border-surface-container-highest w-full py-20" role="contentinfo">
  <div class="grid grid-cols-2 md:grid-cols-5 gap-gutter px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    
    {% comment %} Left Branding Column {% endcomment %}
    <div class="col-span-2">
      <h2 class="font-headline-lg text-headline-lg text-primary mb-6 uppercase tracking-tighter">ESCAPE CLOTHING</h2>
      <p class="font-body-md text-ink-muted max-w-xs mb-8">
        {{ section.settings.brand_description | default: "Premium urban streetwear engineered for those who refuse to fit in. Designed in India, inspired by global street culture." }}
      </p>
      
      <div class="flex gap-4">
        {%- if settings.social_instagram_link != blank -%}
          <a class="w-10 h-10 border border-outline-variant flex items-center justify-center hover:bg-primary hover:text-on-primary transition-all" href="{{ settings.social_instagram_link }}" target="_blank">
            <span class="material-symbols-outlined text-lg">public</span>
          </a>
        {%- endif -%}
        
        <a class="w-10 h-10 border border-outline-variant flex items-center justify-center hover:bg-primary hover:text-on-primary transition-all" href="https://wa.me/{{ settings.social_whatsapp_phone | replace: '+', '' | replace: ' ', '' | default: '918261094774' }}?text={{ settings.social_whatsapp_message | url_encode }}" target="_blank">
          <span class="material-symbols-outlined text-lg">share</span>
        </a>
      </div>
    </div>

    {% comment %} Columns for Navigation {% endcomment %}
    <div>
      <h4 class="font-label-lg text-label-lg text-primary uppercase mb-6">SHOP</h4>
      <ul class="space-y-4">
        <li><a class="font-label-lg text-label-lg text-ink-muted hover:text-primary transition-colors" href="/collections/new-arrivals">NEW ARRIVALS</a></li>
        <li><a class="font-label-lg text-label-lg text-ink-muted hover:text-primary transition-colors" href="/collections/jerseys">JERSEYS</a></li>
        <li><a class="font-label-lg text-label-lg text-ink-muted hover:text-primary transition-colors" href="/collections/oversized-tees">OVERSIZED TEES</a></li>
        <li><a class="font-label-lg text-label-lg text-ink-muted hover:text-primary transition-colors" href="/collections/999-drop">₹999 DROP</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-label-lg text-label-lg text-primary uppercase mb-6">SUPPORT</h4>
      <ul class="space-y-4">
        <li><a class="font-label-lg text-label-lg text-ink-muted hover:text-primary transition-colors" href="/pages/contact">CONTACT US</a></li>
        <li><a class="font-label-lg text-label-lg text-ink-muted hover:text-primary transition-colors" href="/pages/track-order">TRACK ORDER</a></li>
        <li><a class="font-label-lg text-label-lg text-ink-muted hover:text-primary transition-colors" href="/policies/refund-policy">RETURNS</a></li>
        <li><a class="font-label-lg text-label-lg text-ink-muted hover:text-primary transition-colors" href="/policies/shipping-policy">SHIPPING</a></li>
      </ul>
    </div>

    <div>
      <h4 class="font-label-lg text-label-lg text-primary uppercase mb-6">POLICIES</h4>
      <ul class="space-y-4">
        <li><a class="font-label-lg text-label-lg text-ink-muted hover:text-primary transition-colors" href="/policies/privacy-policy">PRIVACY POLICY</a></li>
        <li><a class="font-label-lg text-label-lg text-ink-muted hover:text-primary transition-colors" href="/policies/terms-of-service">TERMS OF SERVICE</a></li>
        <li><a class="font-label-lg text-label-lg text-ink-muted hover:text-primary transition-colors" href="https://wa.me/{{ settings.social_whatsapp_phone | replace: '+', '' | replace: ' ', '' | default: '918261094774' }}?text={{ settings.social_whatsapp_message | url_encode }}">WHATSAPP</a></li>
        <li><a class="font-label-lg text-label-lg text-ink-muted hover:text-primary transition-colors" href="{{ settings.social_instagram_link | default: 'https://instagram.com/escape_clothing17' }}">INSTAGRAM</a></li>
      </ul>
    </div>
  </div>

  <div class="mt-20 pt-8 border-t border-outline-variant px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto text-center">
    <p class="font-label-lg text-xs text-ink-muted">© {{ 'now' | date: "%Y" }} ESCAPE CLOTHING. ALL RIGHTS RESERVED.</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand Description",
      "default": "Premium urban streetwear engineered for those who refuse to fit in. Designed in India, inspired by global street culture."
    }
  ]
}
{% endschema %}
