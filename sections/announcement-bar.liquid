{% comment %}
   Escape Clothing - Announcement Bar Section (Redesigned with Tailwind CSS)
{% endcomment %}

<div class="announcement-bar bg-alert-drop text-white py-2 text-center font-label-lg text-[11px] tracking-widest uppercase relative z-50 overflow-hidden h-9 flex items-center justify-center" id="AnnouncementBar-{{ section.id }}">
  <div class="max-w-container-max mx-auto px-4 w-full h-full relative">
    {%- for block in section.blocks -%}
      <div class="announcement-bar__message absolute inset-0 opacity-0 flex items-center justify-center transition-all duration-500 {% if forloop.first %}active opacity-100 translate-y-0{% else %}translate-y-4{% endif %}" {{ block.shopify_attributes }}>
        <span>{{ block.settings.text }}</span>
      </div>
    {%- endfor -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const messages = document.querySelectorAll('#AnnouncementBar-{{ section.id }} .announcement-bar__message');
    if (messages.length <= 1) return;

    let currentIndex = 0;
    const intervalTime = {{ section.settings.interval | default: 4 }} * 1000;

    setInterval(() => {
      messages[currentIndex].classList.remove('active', 'opacity-100', 'translate-y-0');
      messages[currentIndex].classList.add('opacity-0', 'translate-y-4');
      currentIndex = (currentIndex + 1) % messages.length;
      messages[currentIndex].classList.remove('opacity-0', 'translate-y-4');
      messages[currentIndex].classList.add('active', 'opacity-100', 'translate-y-0');
    }, intervalTime);
  });
</script>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FF3B30"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "interval",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Message Rotation Delay",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Announcement Text",
          "default": "🚚 Free Shipping on orders above ₹999"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement",
        "settings": {
          "text": "🚚 Free Shipping on orders above ₹999"
        }
      },
      {
        "type": "announcement",
        "settings": {
          "text": "💳 Secure Payments via Cashfree (UPI/Cards)"
        }
      },
      {
        "type": "announcement",
        "settings": {
          "text": "📦 Cash on Delivery (COD) Available"
        }
      },
      {
        "type": "announcement",
        "settings": {
          "text": "🔄 Easy 7-Day Returns & Exchanges"
        }
      }
    ]
  }
}
{% endschema %}
