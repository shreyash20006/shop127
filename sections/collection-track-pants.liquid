{% comment %}
   Escape Clothing - Track Pants Section (OS 2.0)
{% endcomment %}

<section class="py-24 bg-surface text-primary" id="TrackPants-{{ section.id }}">
  <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <div class="flex justify-between items-end mb-12">
      <div>
        <h2 class="font-headline-lg text-headline-lg uppercase text-primary">
          {{ section.settings.title | default: "TRACK PANTS" }}
        </h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="font-label-lg text-label-lg text-outline mt-2">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
      <a class="text-primary font-label-lg text-label-lg border-b border-primary hover:text-outline hover:border-outline transition-all" 
         href="{{ collections[section.settings.collection].url | default: '/collections/track-pants' }}">
        VIEW ALL
      </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-gutter">
      {%- assign track_collection = collections[section.settings.collection | default: 'track-pants'] -%}
      {%- if track_collection != blank and track_collection.products_count > 0 -%}
        {%- for product in track_collection.products limit: section.settings.products_limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {% comment %} Fallback items {% endcomment %}
        {%- for i in (1..section.settings.products_limit) -%}
          <div class="group cursor-pointer">
            <div class="relative aspect-3-4 bg-surface-accent mb-6 overflow-hidden border border-outline-variant/30">
              <span class="absolute top-4 left-4 z-10 bg-primary text-on-primary font-label-lg text-[10px] px-2 py-1 uppercase">TRACKPANTS</span>
              <div class="w-full h-full bg-surface-container/60 animate-pulse"></div>
            </div>
            <h3 class="font-title-lg text-title-lg text-primary uppercase tracking-tight">HEAVYWEIGHT JOGGERS</h3>
            <p class="font-price-display text-price-display text-primary mt-1">₹2,199</p>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Track Pants",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading Text",
      "default": "TRACK PANTS"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading Text",
      "default": "STREET COMFORT PIECES"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 4,
      "max": 16,
      "step": 4,
      "label": "Number of Products to Show",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Track Pants",
      "category": "Products"
    }
  ]
}
{% endschema %}
