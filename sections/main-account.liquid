{% comment %}
   Escape Clothing - Customer Account Dashboard (OS 2.0)
{% endcomment %}

<section class="py-24 bg-surface text-primary" id="CustomerAccount-{{ section.id }}">
  <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center border-b border-outline-variant pb-8 mb-12">
      <div>
        <h1 class="font-display-lg text-5xl md:text-7xl uppercase tracking-tighter">MY ACCOUNT</h1>
        <p class="font-label-lg text-label-lg text-outline mt-2">WELCOME BACK, {{ customer.name | default: "STREETWEAR CULT MEMBER" }}</p>
      </div>
      <a href="{{ routes.account_logout_url }}" class="mt-4 md:mt-0 bg-transparent border border-outline hover:border-primary text-primary px-8 py-3 font-label-lg text-xs uppercase tracking-widest transition-all">
        LOG OUT
      </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Order History -->
      <div class="lg:col-span-2">
        <h2 class="font-display-lg text-3xl uppercase tracking-widest mb-6">ORDER HISTORY</h2>
        
        {%- paginate customer.orders by 20 -%}
          {%- if customer.orders.size > 0 -%}
            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse">
                <thead>
                  <tr class="border-b border-outline-variant text-outline font-label-lg text-xs uppercase tracking-wider">
                    <th class="py-4 pr-4">Order</th>
                    <th class="py-4 px-4">Date</th>
                    <th class="py-4 px-4">Payment</th>
                    <th class="py-4 px-4">Fulfillment</th>
                    <th class="py-4 pl-4 text-right">Total</th>
                  </tr>
                </thead>
                <tbody>
                  {%- for order in customer.orders -%}
                    <tr class="border-b border-outline-variant/40 hover:bg-surface-accent transition-colors font-body-md text-sm">
                      <td class="py-4 pr-4">
                        <a href="{{ order.customer_url }}" class="text-primary hover:text-alert-drop underline transition-colors font-semibold">
                          {{ order.name }}
                        </a>
                      </td>
                      <td class="py-4 px-4 text-outline">{{ order.created_at | time_tag: format: 'date' }}</td>
                      <td class="py-4 px-4">
                        <span class="inline-block px-3 py-1 text-[11px] font-semibold tracking-wider uppercase border {% if order.financial_status == 'paid' %}border-green-500/30 text-green-500 bg-green-500/5{% else %}border-amber-500/30 text-amber-500 bg-amber-500/5{% endif %}">
                          {{ order.financial_status_label }}
                        </span>
                      </td>
                      <td class="py-4 px-4">
                        <span class="inline-block px-3 py-1 text-[11px] font-semibold tracking-wider uppercase border {% if order.fulfillment_status == 'fulfilled' %}border-blue-500/30 text-blue-500 bg-blue-500/5{% else %}border-outline-variant text-outline bg-surface-container{% endif %}">
                          {{ order.fulfillment_status_label }}
                        </span>
                      </td>
                      <td class="py-4 pl-4 text-right font-semibold text-primary">{{ order.total_price | money }}</td>
                    </tr>
                  {%- endfor -%}
                </tbody>
              </table>
            </div>
            {%- if paginate.pages > 1 -%}
              <div class="flex justify-center mt-8 gap-4 font-label-lg text-xs">
                {{ paginate | default_pagination }}
              </div>
            {%- endif -%}
          {%- else -%}
            <div class="border border-dashed border-outline-variant p-12 text-center bg-surface-accent">
              <span class="material-symbols-outlined text-4xl text-outline mb-4">shopping_bag</span>
              <p class="font-label-lg text-sm text-outline uppercase tracking-wider">YOU HAVEN'T PLACED ANY ORDERS YET.</p>
              <a href="{{ routes.all_products_collection_url }}" class="inline-block mt-6 bg-primary text-on-primary px-8 py-3 font-label-lg text-xs uppercase tracking-widest hover:opacity-90 transition-all">
                START SHOPPING
              </a>
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>

      <!-- Account Details & Addresses -->
      <div>
        <h2 class="font-display-lg text-3xl uppercase tracking-widest mb-6">ACCOUNT DETAILS</h2>
        <div class="bg-surface-accent border border-outline-variant p-8 flex flex-col justify-between h-auto">
          <div>
            <h3 class="font-label-lg text-sm uppercase tracking-wider text-primary mb-4">{{ customer.name }}</h3>
            <p class="font-body-md text-sm text-outline mb-6">{{ customer.email }}</p>
            
            {%- if customer.default_address != blank -%}
              <div class="font-body-md text-sm text-outline space-y-1">
                <p class="text-primary font-semibold uppercase text-xs tracking-wider mb-2">DEFAULT ADDRESS</p>
                <p>{{ customer.default_address.address1 }}</p>
                {%- if customer.default_address.address2 != blank -%}
                  <p>{{ customer.default_address.address2 }}</p>
                {%- endif -%}
                <p>{{ customer.default_address.city }}, {{ customer.default_address.province_code }} {{ customer.default_address.zip }}</p>
                <p>{{ customer.default_address.country }}</p>
                {%- if customer.default_address.phone != blank -%}
                  <p class="mt-2">{{ customer.default_address.phone }}</p>
                {%- endif -%}
              </div>
            {%- else -%}
              <p class="font-body-md text-sm text-outline">No default address specified.</p>
            {%- endif -%}
          </div>
          
          <a href="{{ routes.addresses_url }}" class="mt-8 block text-center bg-primary text-on-primary px-8 py-4 font-label-lg text-xs uppercase tracking-widest hover:opacity-90 transition-all">
            MANAGE ADDRESSES ({{ customer.addresses_count }})
          </a>
        </div>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Customer Account",
  "settings": []
}
{% endschema %}
