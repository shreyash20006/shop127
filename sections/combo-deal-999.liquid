{% comment %}
   Escape Clothing - 999 Drop Banner Section (Redesigned with Tailwind CSS)
{% endcomment %}

<section class="py-24 bg-[#111111] relative overflow-hidden" id="ComboDrop-{{ section.id }}">
  <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png')"></div>
  <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto relative z-10 text-center">
    <h2 class="font-display-lg text-7xl md:text-display-lg text-primary uppercase tracking-tighter mb-4">
      {{ section.settings.title | default: "3 FOR ₹999" }}
    </h2>
    <p class="font-label-lg text-label-lg text-alert-drop mb-12 tracking-widest uppercase">
      {{ section.settings.subtext | default: "LIMITED TIME DROP — ENDING SOON" }}
    </p>
    
    {% comment %} Countdown Timer {% endcomment %}
    <div class="flex justify-center gap-4 md:gap-8 mb-12" data-end-date="{{ section.settings.end_date | default: '2026-12-31T23:59:59' }}">
      <div class="bg-surface-accent border border-outline-variant w-20 h-24 md:w-28 md:h-32 flex flex-col items-center justify-center">
        <span class="font-headline-lg text-headline-lg text-primary" id="TimerDays-{{ section.id }}">00</span>
        <span class="font-label-lg text-[10px] text-outline uppercase">Days</span>
      </div>
      <div class="bg-surface-accent border border-outline-variant w-20 h-24 md:w-28 md:h-32 flex flex-col items-center justify-center">
        <span class="font-headline-lg text-headline-lg text-primary" id="TimerHours-{{ section.id }}">00</span>
        <span class="font-label-lg text-[10px] text-outline uppercase">Hours</span>
      </div>
      <div class="bg-surface-accent border border-outline-variant w-20 h-24 md:w-28 md:h-32 flex flex-col items-center justify-center">
        <span class="font-headline-lg text-headline-lg text-primary" id="TimerMinutes-{{ section.id }}">00</span>
        <span class="font-label-lg text-[10px] text-outline uppercase">Mins</span>
      </div>
      <div class="bg-surface-accent border border-outline-variant w-20 h-24 md:w-28 md:h-32 flex flex-col items-center justify-center">
        <span class="font-headline-lg text-headline-lg text-primary" id="TimerSeconds-{{ section.id }}">00</span>
        <span class="font-label-lg text-[10px] text-outline uppercase">Secs</span>
      </div>
    </div>
    
    <a href="{{ section.settings.button_link | default: '/collections/999-drop' }}" 
       class="bg-alert-drop text-white px-12 py-5 font-label-lg text-label-lg uppercase tracking-widest hover:scale-105 transition-all active:scale-95 shadow-[0_0_20px_rgba(255,59,48,0.3)] inline-block">
      {{ section.settings.button_text | default: "SHOP THE DROP" }}
    </a>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const parent = document.getElementById('ComboDrop-{{ section.id }}');
    if (!parent) return;

    const timerContainer = parent.querySelector('[data-end-date]');
    if (!timerContainer) return;

    const endDateStr = timerContainer.getAttribute('data-end-date');
    const endDate = new Date(endDateStr).getTime();

    const dEl = document.getElementById('TimerDays-{{ section.id }}');
    const hEl = document.getElementById('TimerHours-{{ section.id }}');
    const mEl = document.getElementById('TimerMinutes-{{ section.id }}');
    const sEl = document.getElementById('TimerSeconds-{{ section.id }}');

    function updateTimer() {
      const now = new Date().getTime();
      const distance = endDate - now;

      if (distance < 0) {
        if (dEl) dEl.innerText = "00";
        if (hEl) hEl.innerText = "00";
        if (mEl) mEl.innerText = "00";
        if (sEl) sEl.innerText = "00";
        return;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      if (dEl) dEl.innerText = days < 10 ? '0' + days : days;
      if (hEl) hEl.innerText = hours < 10 ? '0' + hours : hours;
      if (mEl) mEl.innerText = minutes < 10 ? '0' + minutes : minutes;
      if (sEl) sEl.innerText = seconds < 10 ? '0' + seconds : seconds;
    }

    updateTimer();
    setInterval(updateTimer, 1000);
  });
</script>

{% schema %}
{
  "name": "Combo Deal 999 Drop",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Promotion Text",
      "default": "3 FOR ₹999"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subheading Text",
      "default": "LIMITED TIME DROP — ENDING SOON"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "Drop End Date (ISO Format)",
      "default": "2026-12-31T23:59:59",
      "info": "Format: YYYY-MM-DDTHH:MM:SS"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP THE DROP"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Combo Deal Drop",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
