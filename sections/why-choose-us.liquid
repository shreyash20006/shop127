{% comment %}
   Escape Clothing - Why Choose Us / Trust Badges Section (Redesigned with Tailwind CSS)
{% endcomment %}

<section class="py-24 border-t border-outline-variant" id="WhyChooseUs-{{ section.id }}">
  <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-gutter">
      
      {% comment %} Card 1 {% endcomment %}
      <div class="flex flex-col items-center text-center p-8 border border-outline-variant hover:border-primary transition-colors group">
        <span class="material-symbols-outlined text-4xl mb-4 text-primary group-hover:scale-110 transition-transform">verified_user</span>
        <h4 class="font-label-lg text-label-lg text-primary uppercase mb-2">PREMIUM QUALITY</h4>
        <p class="font-body-md text-sm text-outline">Heavy-weight fabrics & superior stitching</p>
      </div>

      {% comment %} Card 2 {% endcomment %}
      <div class="flex flex-col items-center text-center p-8 border border-outline-variant hover:border-primary transition-colors group">
        <span class="material-symbols-outlined text-4xl mb-4 text-primary group-hover:scale-110 transition-transform">local_shipping</span>
        <h4 class="font-label-lg text-label-lg text-primary uppercase mb-2">FAST SHIPPING</h4>
        <p class="font-body-md text-sm text-outline">Across India in 3-5 business days</p>
      </div>

      {% comment %} Card 3 {% endcomment %}
      <div class="flex flex-col items-center text-center p-8 border border-outline-variant hover:border-primary transition-colors group">
        <span class="material-symbols-outlined text-4xl mb-4 text-primary group-hover:scale-110 transition-transform">encrypted</span>
        <h4 class="font-label-lg text-label-lg text-primary uppercase mb-2">SECURE PAYMENTS</h4>
        <p class="font-body-md text-sm text-outline">100% safe & encrypted transactions</p>
      </div>

      {% comment %} Card 4 {% endcomment %}
      <div class="flex flex-col items-center text-center p-8 border border-outline-variant hover:border-primary transition-colors group">
        <span class="material-symbols-outlined text-4xl mb-4 text-primary group-hover:scale-110 transition-transform">keyboard_return</span>
        <h4 class="font-label-lg text-label-lg text-primary uppercase mb-2">EASY RETURNS</h4>
        <p class="font-body-md text-sm text-outline">No questions asked return policy</p>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Choose Us",
  "settings": [],
  "presets": [
    {
      "name": "Why Choose Us",
      "category": "Brand"
    }
  ]
}
{% endschema %}
