{% comment %}
   Escape Clothing - Why Choose Us / Trust Badges Section
{% endcomment %}

<section class="why-choose-us reveal" id="WhyChooseUs-{{ section.id }}">
  <div class="container">
    
    <div class="why-choose-us__grid grid">
      
      {% comment %} Card 1 {% endcomment %}
      <div class="trust-card text-center flex align-center justify-center">
        <div class="trust-card__icon-wrap">
          <svg class="trust-icon" viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="1.5" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
        </div>
        <h3 class="trust-card__title">PREMIUM QUALITY</h3>
        <p class="trust-card__text">Handpicked premium fabrics, custom oversized fit, and durable double-stitch craft.</p>
      </div>

      {% comment %} Card 2 {% endcomment %}
      <div class="trust-card text-center flex align-center justify-center">
        <div class="trust-card__icon-wrap">
          <svg class="trust-icon" viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="1.5" fill="none"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
        </div>
        <h3 class="trust-card__title">FAST SHIPPING</h3>
        <p class="trust-card__text">Delivered in 3–7 business days PAN India. Dispatched from Nagpur within 24 hours.</p>
      </div>

      {% comment %} Card 3 {% endcomment %}
      <div class="trust-card text-center flex align-center justify-center">
        <div class="trust-card__icon-wrap">
          <svg class="trust-icon" viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="1.5" fill="none"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        </div>
        <h3 class="trust-card__title">SECURE PAYMENTS</h3>
        <p class="trust-card__text">100% encrypted Cashfree Checkout. Pay via UPI, Credit/Debit cards, Net Banking or COD.</p>
      </div>

      {% comment %} Card 4 {% endcomment %}
      <div class="trust-card text-center flex align-center justify-center">
        <div class="trust-card__icon-wrap">
          <svg class="trust-icon" viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="1.5" fill="none"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
        </div>
        <h3 class="trust-card__title">EASY RETURNS</h3>
        <p class="trust-card__text">Hassle-free 7-day return and exchange window. Unused items, original tags intact.</p>
      </div>

    </div>

  </div>
</section>

<style>
  .why-choose-us {
    padding: 80px 0;
    background-color: var(--surface-primary);
    border-bottom: 1px solid var(--border-color);
  }
  .why-choose-us__grid {
    grid-template-columns: 1fr;
    gap: 32px;
  }
  .trust-card {
    flex-direction: column;
    padding: 24px;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    transition: var(--transition-smooth);
  }
  .trust-card:hover {
    border-color: var(--text-primary);
    transform: translateY(-5px);
  }
  .trust-card__icon-wrap {
    width: 72px;
    height: 72px;
    background-color: var(--surface-secondary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--highlight-color);
    margin-bottom: 20px;
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .trust-card:hover .trust-card__icon-wrap {
    transform: scale(1.15) rotate(5deg);
  }
  .trust-card__title {
    font-size: 2.2rem;
    color: var(--text-primary);
    margin-bottom: 12px;
    letter-spacing: 1.5px;
  }
  .trust-card__text {
    font-size: 1.4rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 280px;
  }

  @media screen and (min-width: 768px) {
    .why-choose-us__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (min-width: 990px) {
    .why-choose-us__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Why Choose Us",
  "settings": [],
  "presets": [
    {
      "name": "Why Choose Us",
      "category": "Brand"
    }
  ]
}
{% endschema %}
