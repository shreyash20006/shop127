{% comment %}
   Escape Clothing - Customer Addresses Management Page (OS 2.0)
{% endcomment %}

<section class="py-24 bg-surface text-primary" id="CustomerAddresses-{{ section.id }}" data-customer-addresses>
  <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center border-b border-outline-variant pb-8 mb-12">
      <div>
        <a href="{{ routes.account_url }}" class="text-xs font-label-lg text-outline hover:text-primary transition-colors uppercase tracking-widest flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-[14px]">arrow_back</span> Back to Account
        </a>
        <h1 class="font-display-lg text-5xl md:text-7xl uppercase tracking-tighter">MANAGE ADDRESSES</h1>
      </div>
      <button type="button" 
              onclick="toggleAddressForm('new')" 
              class="mt-4 md:mt-0 bg-primary text-on-primary px-8 py-4 font-label-lg text-xs uppercase tracking-widest hover:opacity-90 transition-all">
        ADD NEW ADDRESS
      </button>
    </div>

    <!-- NEW ADDRESS FORM -->
    <div id="AddAddress" class="hidden bg-surface-accent border border-outline-variant p-8 mb-12 max-w-2xl mx-auto space-y-6">
      <h2 class="font-display-lg text-3xl uppercase tracking-widest">ADD A NEW ADDRESS</h2>
      
      {%- form 'customer_address', customer.new_address, class: 'space-y-6' -%}
        <div class="grid grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="AddressFirstNameNew" class="block font-label-lg text-xs text-outline uppercase tracking-wider">First Name</label>
            <input type="text" name="address[first_name]" id="AddressFirstNameNew" value="{{ form.first_name }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
          </div>
          <div class="space-y-2">
            <label for="AddressLastNameNew" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Last Name</label>
            <input type="text" name="address[last_name]" id="AddressLastNameNew" value="{{ form.last_name }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
          </div>
        </div>

        <div class="space-y-2">
          <label for="AddressCompanyNew" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Company</label>
          <input type="text" name="address[company]" id="AddressCompanyNew" value="{{ form.company }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
        </div>

        <div class="space-y-2">
          <label for="AddressAddress1New" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Address 1</label>
          <input type="text" name="address[address1]" id="AddressAddress1New" value="{{ form.address1 }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
        </div>

        <div class="space-y-2">
          <label for="AddressAddress2New" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Address 2</label>
          <input type="text" name="address[address2]" id="AddressAddress2New" value="{{ form.address2 }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
        </div>

        <div class="grid grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="AddressCityNew" class="block font-label-lg text-xs text-outline uppercase tracking-wider">City</label>
            <input type="text" name="address[city]" id="AddressCityNew" value="{{ form.city }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
          </div>
          <div class="space-y-2">
            <label for="AddressCountryNew" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Country</label>
            <select name="address[country]" id="AddressCountryNew" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
              {{ all_country_option_tags }}
            </select>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="AddressProvinceNew" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Province</label>
            <input type="text" name="address[province]" id="AddressProvinceNew" value="{{ form.province }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
          </div>
          <div class="space-y-2">
            <label for="AddressZipNew" class="block font-label-lg text-xs text-outline uppercase tracking-wider">PIN Code / Zip</label>
            <input type="text" name="address[zip]" id="AddressZipNew" value="{{ form.zip }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
          </div>
        </div>

        <div class="space-y-2">
          <label for="AddressPhoneNew" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Phone Number</label>
          <input type="text" name="address[phone]" id="AddressPhoneNew" value="{{ form.phone }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
        </div>

        <div class="flex items-center gap-3 py-2">
          {{ form.set_as_default_checkbox }}
          <label for="address_default_address_new" class="font-body-md text-sm text-outline uppercase tracking-wider cursor-pointer">Set as default address</label>
        </div>

        <div class="flex gap-4 pt-4">
          <button type="submit" class="flex-1 bg-primary text-on-primary py-4 font-label-lg text-label-lg uppercase tracking-widest hover:opacity-90 transition-all">
            ADD ADDRESS
          </button>
          <button type="button" 
                  onclick="toggleAddressForm('new')" 
                  class="flex-1 bg-transparent border border-outline hover:border-primary text-primary py-4 font-label-lg text-xs uppercase tracking-widest transition-all">
            CANCEL
          </button>
        </div>
      {%- endform -%}
    </div>

    <!-- ADDRESSES LIST -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {%- for address in customer.addresses -%}
        <div class="bg-surface-accent border border-outline-variant p-8 flex flex-col justify-between" id="AddressCard-{{ address.id }}">
          <div>
            <div class="flex items-center gap-3 mb-6">
              <span class="font-label-lg text-sm uppercase tracking-wider text-primary">{{ address.name }}</span>
              {%- if address == customer.default_address -%}
                <span class="bg-primary text-on-primary px-3 py-1 text-[10px] font-bold tracking-widest uppercase">DEFAULT</span>
              {%- endif -%}
            </div>
            
            <div class="font-body-md text-sm text-outline space-y-1">
              <p>{{ address.address1 }}</p>
              {%- if address.address2 != blank -%}
                <p>{{ address.address2 }}</p>
              {%- endif -%}
              <p>{{ address.city }}, {{ address.province_code }} {{ address.zip }}</p>
              <p>{{ address.country }}</p>
              {%- if address.phone != blank -%}
                <p class="mt-4 text-primary font-semibold">{{ address.phone }}</p>
              {%- endif -%}
            </div>
          </div>

          <div class="flex gap-4 mt-8 border-t border-outline-variant pt-6">
            <button type="button" 
                    onclick="toggleAddressForm('edit-{{ address.id }}')" 
                    class="flex-1 bg-transparent border border-outline hover:border-primary text-primary py-2 font-label-lg text-xs uppercase tracking-wider transition-all">
              EDIT
            </button>
            <button type="button" 
                    onclick="deleteAddress('{{ address.id }}')" 
                    class="flex-1 bg-transparent border border-alert-drop/30 hover:bg-alert-drop/10 text-alert-drop py-2 font-label-lg text-xs uppercase tracking-wider transition-all">
              DELETE
            </button>
          </div>
        </div>

        <!-- EDIT ADDRESS FORM FOR THIS ADDRESS -->
        <div id="EditAddress-{{ address.id }}" class="hidden col-span-full bg-surface-accent border border-outline-variant p-8 my-6 max-w-2xl mx-auto space-y-6 w-full">
          <h2 class="font-display-lg text-3xl uppercase tracking-widest">EDIT ADDRESS</h2>
          
          {%- form 'customer_address', address, class: 'space-y-6' -%}
            <div class="grid grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="AddressFirstName-{{ address.id }}" class="block font-label-lg text-xs text-outline uppercase tracking-wider">First Name</label>
                <input type="text" name="address[first_name]" id="AddressFirstName-{{ address.id }}" value="{{ form.first_name }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
              </div>
              <div class="space-y-2">
                <label for="AddressLastName-{{ address.id }}" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Last Name</label>
                <input type="text" name="address[last_name]" id="AddressLastName-{{ address.id }}" value="{{ form.last_name }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
              </div>
            </div>

            <div class="space-y-2">
              <label for="AddressCompany-{{ address.id }}" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Company</label>
              <input type="text" name="address[company]" id="AddressCompany-{{ address.id }}" value="{{ form.company }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
            </div>

            <div class="space-y-2">
              <label for="AddressAddress1-{{ address.id }}" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Address 1</label>
              <input type="text" name="address[address1]" id="AddressAddress1-{{ address.id }}" value="{{ form.address1 }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
            </div>

            <div class="space-y-2">
              <label for="AddressAddress2-{{ address.id }}" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Address 2</label>
              <input type="text" name="address[address2]" id="AddressAddress2-{{ address.id }}" value="{{ form.address2 }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
            </div>

            <div class="grid grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="AddressCity-{{ address.id }}" class="block font-label-lg text-xs text-outline uppercase tracking-wider">City</label>
                <input type="text" name="address[city]" id="AddressCity-{{ address.id }}" value="{{ form.city }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
              </div>
              <div class="space-y-2">
                <label for="AddressCountry-{{ address.id }}" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Country</label>
                <select name="address[country]" id="AddressCountry-{{ address.id }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
                  {{ all_country_option_tags }}
                </select>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="AddressProvince-{{ address.id }}" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Province</label>
                <input type="text" name="address[province]" id="AddressProvince-{{ address.id }}" value="{{ form.province }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
              </div>
              <div class="space-y-2">
                <label for="AddressZip-{{ address.id }}" class="block font-label-lg text-xs text-outline uppercase tracking-wider">PIN Code / Zip</label>
                <input type="text" name="address[zip]" id="AddressZip-{{ address.id }}" value="{{ form.zip }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
              </div>
            </div>

            <div class="space-y-2">
              <label for="AddressPhone-{{ address.id }}" class="block font-label-lg text-xs text-outline uppercase tracking-wider">Phone Number</label>
              <input type="text" name="address[phone]" id="AddressPhone-{{ address.id }}" value="{{ form.phone }}" class="w-full bg-surface border border-outline-variant p-3 text-primary font-label-lg focus:border-primary focus:ring-0 rounded-none transition-colors">
            </div>

            <div class="flex items-center gap-3 py-2">
              {{ form.set_as_default_checkbox }}
              <label for="address_default_address_{{ address.id }}" class="font-body-md text-sm text-outline uppercase tracking-wider cursor-pointer">Set as default address</label>
            </div>

            <div class="flex gap-4 pt-4">
              <button type="submit" class="flex-1 bg-primary text-on-primary py-4 font-label-lg text-label-lg uppercase tracking-widest hover:opacity-90 transition-all">
                UPDATE ADDRESS
              </button>
              <button type="button" 
                      onclick="toggleAddressForm('edit-{{ address.id }}')" 
                      class="flex-1 bg-transparent border border-outline hover:border-primary text-primary py-4 font-label-lg text-xs uppercase tracking-widest transition-all">
                CANCEL
              </button>
            </div>
          {%- endform -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
  function toggleAddressForm(formId) {
    if (formId === 'new') {
      document.getElementById('AddAddress').classList.toggle('hidden');
    } else {
      document.getElementById('EditAddress-' + formId.split('-')[1]).classList.toggle('hidden');
    }
  }

  function deleteAddress(addressId) {
    if (confirm("Are you sure you want to delete this address?")) {
      Shopify.postLink('/account/addresses/' + addressId, {
        parameters: { _method: 'delete' }
      });
    }
  }
</script>
