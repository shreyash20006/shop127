{% comment %}
   Escape Clothing - 404 Page Not Found Section
{% endcomment %}

<section class="error-404-section reveal text-center" style="padding: 140px 24px;">
  <div class="container" style="max-width: 600px;">
    <h1 style="font-size: 12rem; color: var(--highlight-color); line-height: 1; margin-bottom: 24px;">404</h1>
    <h2 style="font-size: 3.6rem; color: #FFFFFF; margin-bottom: 16px;">PAGE NOT FOUND</h2>
    <p style="font-size: 1.6rem; color: var(--text-muted); margin-bottom: 40px; line-height: 1.6;">
      The drop you are looking for has expired, or the page has escaped our servers. Head back to the store homepage.
    </p>
    <a href="/" class="btn btn-primary btn-hover-slide">BACK TO HOMEPAGE</a>
  </div>
</section>

<style>
  .error-404-section {
    background-color: var(--bg-color);
  }
</style>

{% schema %}
{
  "name": "404 Error",
  "settings": []
}
{% endschema %}
