{% comment %}
   Escape Clothing - Featured Collection Grid (OS 2.0)
{% endcomment %}

<section class="py-24 bg-surface text-primary" id="FeaturedCollection-{{ section.id }}">
  <div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <div class="flex justify-between items-end mb-12">
      <div>
        <h2 class="font-headline-lg text-headline-lg uppercase text-primary">
          {{ section.settings.title | default: "FEATURED COLLECTION" }}
        </h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="font-label-lg text-label-lg text-outline mt-2">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.collection != blank -%}
        <a class="text-primary font-label-lg text-label-lg border-b border-primary hover:text-outline hover:border-outline transition-all" 
           href="{{ collections[section.settings.collection].url }}">
          VIEW ALL
        </a>
      {%- endif -%}
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-gutter">
      {%- assign featured_collection = collections[section.settings.collection] -%}
      {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
        {%- for product in featured_collection.products limit: section.settings.products_limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {% comment %} Fallback placeholder items {% endcomment %}
        {%- for i in (1..section.settings.products_limit) -%}
          <div class="group cursor-pointer">
            <div class="relative aspect-3-4 bg-surface-accent mb-6 overflow-hidden border border-outline-variant/30">
              <span class="absolute top-4 left-4 z-10 bg-primary text-on-primary font-label-lg text-[10px] px-2 py-1 uppercase">NEW</span>
              <div class="w-full h-full bg-surface-container/60 animate-pulse"></div>
              <button class="absolute bottom-0 w-full bg-primary text-on-primary py-4 font-label-lg uppercase transform translate-y-full group-hover:translate-y-0 transition-transform duration-300">ADD TO CART</button>
            </div>
            <h3 class="font-title-lg text-title-lg text-primary uppercase tracking-tight">STREETWEAR PIECE</h3>
            <p class="font-price-display text-price-display text-primary mt-1">₹1,999</p>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading Text",
      "default": "FEATURED DROP"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading Text",
      "default": "HANDPICKED AESTHETICS"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 4,
      "max": 16,
      "step": 4,
      "label": "Number of Products to Show",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "category": "Products"
    }
  ]
}
{% endschema %}
