{% comment %}
   Escape Clothing - Reusable Product Card (Redesigned with Tailwind CSS)
{% endcomment %}

<div class="group cursor-pointer flex flex-col relative {% unless product.available %}opacity-70{% endunless %}" data-product-id="{{ product.id }}">
  
  {% comment %} Image Container {% endcomment %}
  <div class="relative aspect-3-4 bg-surface mb-4 overflow-hidden">
    
    {% comment %} Status Badges {% endcomment %}
    {%- if product.available == false -%}
      <span class="absolute top-4 left-4 z-10 bg-outline-variant text-ink-muted font-label-lg text-[10px] px-2 py-1 uppercase">SOLD OUT</span>
    {%- elsif product.compare_at_price > product.price -%}
      <span class="absolute top-4 left-4 z-10 bg-alert-drop text-white font-label-lg text-[10px] px-2 py-1 uppercase">SALE</span>
    {%- elsif product.tags contains 'hot' or show_hot_badge -%}
      <span class="absolute top-4 left-4 z-10 bg-alert-drop text-white font-label-lg text-[10px] px-2 py-1 uppercase">🔥 HOT</span>
    {%- elsif product.tags contains 'new' -%}
      <span class="absolute top-4 left-4 z-10 bg-primary text-on-primary font-label-lg text-[10px] px-2 py-1 uppercase">NEW</span>
    {%- endif -%}

    {% comment %} Wishlist Heart Toggle {% endcomment %}
    <button class="absolute top-4 right-4 z-10 w-9 h-9 bg-black/60 rounded-full flex items-center justify-center text-outline hover:text-alert-drop hover:scale-110 transition-all js-wishlist-toggle" 
            aria-label="Add to Wishlist" 
            onclick="toggleWishlistItem('{{ product.id }}', this)">
      <svg class="heart-icon" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
    </button>

    {% comment %} Main Link & Images {% endcomment %}
    <a href="{{ product.url | within: collection }}" class="w-full h-full block">
      <div class="w-full h-full relative">
        {%- if product.featured_image != blank -%}
          <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
               src="{{ product.featured_image | image_url: width: 600, height: 800, crop: 'center' }}" 
               alt="{{ product.title }}" 
               loading="lazy">
        {%- else -%}
          <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
               src="https://images.unsplash.com/photo-1521572267360-ee0c2909d518?q=80&w=600&auto=format&fit=crop" 
               alt="Placeholder apparel">
        {%- endif -%}
      </div>
    </a>

    {% comment %} Slide-up Add to Cart CTA {% endcomment %}
    {%- if product.available -%}
      <div class="absolute bottom-0 w-full transform translate-y-full group-hover:translate-y-0 transition-transform duration-300 z-20">
        <button class="w-full bg-primary text-on-primary py-4 font-label-lg uppercase hover:opacity-90 active:scale-95 transition-all" 
                onclick="toggleQuickAddBox(event, this)">
          ADD TO CART
        </button>
        
        {% comment %} Inline Mini Size selector popup {% endcomment %}
        <div class="quick-add-sizes-box absolute bottom-0 left-0 w-full bg-surface-container border-t border-outline-variant p-4 flex flex-wrap justify-center gap-2 transform translate-y-full transition-transform duration-300">
          <p class="font-label-lg text-[10px] text-outline w-full text-center mb-2 uppercase">SELECT SIZE</p>
          {%- for option in product.options_with_values -%}
            {%- assign option_name_down = option.name | downcase -%}
            {%- if option_name_down contains 'size' -%}
              {%- for value in option.values -%}
                {%- assign target_variant = blank -%}
                {%- for variant in product.variants -%}
                  {%- if variant.title contains value -%}
                    {%- assign target_variant = variant -%}
                  {%- endif -%}
                {%- endfor -%}

                <button class="min-w-[40px] h-9 border border-outline-variant text-xs font-semibold flex items-center justify-center bg-surface text-primary hover:border-primary hover:bg-primary hover:text-on-primary transition-all {% unless target_variant.available %}line-through opacity-40 cursor-not-allowed{% endunless %}" 
                        {% if target_variant.available %}onclick="addVariantToCartAjax('{{ target_variant.id }}', this)"{% else %}disabled{% endif %}>
                  {{ value }}
                </button>
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}
          <button class="absolute top-2 right-2 text-outline hover:text-primary text-lg" onclick="closeQuickAddBox(event, this)">&times;</button>
        </div>
      </div>
    {%- endif -%}
  </div>

  {% comment %} Details {% endcomment %}
  <div class="flex flex-col">
    <p class="font-label-lg text-[10px] text-outline uppercase tracking-widest mb-1">{{ product.vendor | default: "ESCAPE CLOTHING" }}</p>
    <h3 class="font-title-lg text-title-lg text-primary uppercase tracking-tight truncate">
      <a href="{{ product.url | within: collection }}">{{ product.title }}</a>
    </h3>
    <p class="font-price-display text-price-display text-primary mt-1">
      ₹{{ product.price | money_without_currency | replace: ',', '' }}
      {%- if product.compare_at_price > product.price -%}
        <span class="text-sm text-outline line-through ml-2 font-normal">₹{{ product.compare_at_price | money_without_currency | replace: ',', '' }}</span>
      {%- endif -%}
    </p>
  </div>
</div>
