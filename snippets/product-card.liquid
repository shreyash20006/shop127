{% comment %}
   Escape Clothing - Reusable Product Card Component
   Parameters:
     - product: Product Object (required)
     - show_hot_badge: Boolean (optional)
{% endcomment %}

<div class="product-card flex flex-column {% unless product.available %}product-card--sold-out{% endunless %}" data-product-id="{{ product.id }}">
  
  {% comment %} Image Container 3:4 aspect-ratio {% endcomment %}
  <div class="product-card__image-container">
    
    {% comment %} Badge Indicators {% endcomment %}
    {%- if product.available == false -%}
      <span class="badge badge-sold-out">SOLD OUT</span>
    {%- elsif product.compare_at_price > product.price -%}
      <span class="badge badge-sale">SALE</span>
    {%- elsif show_hot_badge or product.tags contains 'hot' -%}
      <span class="badge badge-hot">🔥 HOT</span>
    {%- elsif product.tags contains 'new' -%}
      <span class="badge badge-new">NEW</span>
    {%- endif -%}

    {% comment %} Wishlist Heart Toggle Icon {% endcomment %}
    <button class="product-card__wishlist-btn js-wishlist-toggle" aria-label="Add to Wishlist" onclick="toggleWishlistItem('{{ product.id }}', this)">
      <svg class="heart-icon" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
    </button>

    {% comment %} Product Images {% endcomment %}
    <a href="{{ product.url | within: collection }}" class="product-card__image-link">
      <div class="product-card__images-wrapper">
        {%- if product.featured_image != blank -%}
          <img class="product-card__image product-card__image--primary" 
               src="{{ product.featured_image | image_url: width: 600, height: 800, crop: 'center' }}" 
               alt="{{ product.title }}" 
               loading="lazy">
        {%- else -%}
          <img class="product-card__image product-card__image--primary" 
               src="https://images.unsplash.com/photo-1521572267360-ee0c2909d518?q=80&w=600&auto=format&fit=crop" 
               alt="Placeholder apparel">
        {%- endif -%}

        {%- if product.images.size > 1 -%}
          <img class="product-card__image product-card__image--secondary" 
               src="{{ product.images[1] | image_url: width: 600, height: 800, crop: 'center' }}" 
               alt="{{ product.title }}" 
               loading="lazy">
        {%- endif -%}
      </div>
    </a>

    {% comment %} Slide-up Quick Add Button {% endcomment %}
    {%- if product.available -%}
      <div class="product-card__quick-add-wrap">
        <button class="product-card__quick-add-trigger js-quick-add-trigger" onclick="toggleQuickAddBox(event, this)">QUICK ADD</button>
        
        {% comment %} Inline Mini Size selector popup {% endcomment %}
        <div class="quick-add-sizes-box flex justify-center align-center">
          <p style="font-size: 1.1rem; font-weight: 700; color: var(--text-muted); width: 100%; text-align: center; margin-bottom: 8px;">SELECT SIZE</p>
          {%- for option in product.options_with_values -%}
            {%- assign option_name_down = option.name | downcase -%}
            {%- if option_name_down contains 'size' -%}
              {%- for value in option.values -%}
                {% comment %} Find matching variant ID {% endcomment %}
                {%- assign target_variant = blank -%}
                {%- for variant in product.variants -%}
                  {%- if variant.title contains value -%}
                    {%- assign target_variant = variant -%}
                  {%- endif -%}
                {%- endfor -%}

                <button class="quick-size-btn {% unless target_variant.available %}disabled{% endunless %}" 
                        {% if target_variant.available %}onclick="addVariantToCartAjax('{{ target_variant.id }}', this)"{% else %}disabled{% endif %}>
                  {{ value }}
                </button>
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}
          <button class="quick-add-close" onclick="closeQuickAddBox(event, this)">&times;</button>
        </div>
      </div>
    {%- endif -%}

  </div>

  {% comment %} Product Text Details {% endcomment %}
  <div class="product-card__info text-center" style="padding: 16px 8px 8px 8px;">
    <p class="product-card__vendor" style="font-size: 1.1rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 4px;">{{ product.vendor | default: "ESCAPE CLOTHING" }}</p>
    
    <h3 class="product-card__title" style="font-size: 1.5rem; font-family: var(--font-body); font-weight: 600; text-transform: uppercase; margin-bottom: 8px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
      <a href="{{ product.url | within: collection }}">{{ product.title }}</a>
    </h3>

    {% render 'star-rating', rating: 4.5 %}

    <div class="product-card__price-row flex align-center justify-center" style="gap: 8px; margin-top: 8px;">
      <span class="product-card__price-current" style="font-size: 1.6rem; font-weight: 700; color: #FFFFFF;">₹{{ product.price | money_without_currency | replace: ',', '' }}</span>
      {%- if product.compare_at_price > product.price -%}
        <span class="product-card__price-compare" style="font-size: 1.3rem; color: var(--text-muted); text-decoration: line-through;">₹{{ product.compare_at_price | money_without_currency | replace: ',', '' }}</span>
      {%- endif -%}
    </div>
  </div>

</div>

<style>
  .product-card {
    position: relative;
    background-color: var(--surface-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    transition: var(--transition-smooth);
    overflow: hidden;
  }
  .product-card:hover {
    border-color: var(--text-primary);
  }
  .product-card__image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
  }
  
  .product-card__images-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
  }
  
  .product-card__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  
  .product-card__image--secondary {
    opacity: 0;
  }
  
  /* Hover effects */
  .product-card:hover .product-card__image--primary {
    {%- if product.images.size > 1 -%}
      opacity: 0;
    {%- else -%}
      transform: scale(1.04);
    {%- endif -%}
  }
  .product-card:hover .product-card__image--secondary {
    opacity: 1;
    transform: scale(1.04);
  }

  /* Wishlist button overlay styling */
  .product-card__wishlist-btn {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
    background-color: rgba(10, 10, 10, 0.7);
    color: var(--text-secondary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: var(--transition-fast);
  }
  .product-card__wishlist-btn:hover {
    color: var(--highlight-color);
    transform: scale(1.1);
  }
  .product-card__wishlist-btn.active {
    color: var(--highlight-color);
    fill: var(--highlight-color);
  }

  /* Quick Add Drawer slide up details */
  .product-card__quick-add-wrap {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    z-index: 4;
  }
  .product-card:hover .product-card__quick-add-wrap {
    transform: translateY(0);
  }
  .product-card__quick-add-trigger {
    width: 100%;
    background-color: var(--text-primary);
    color: var(--accent-inverse);
    padding: 14px;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-align: center;
    border: none;
  }
  .quick-add-sizes-box {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    background-color: var(--surface-primary);
    padding: 16px;
    border-top: 1px solid var(--border-color);
    flex-wrap: wrap;
    gap: 8px;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  .quick-add-sizes-box.active {
    transform: translateY(0);
  }
  .quick-size-btn {
    min-width: 40px;
    height: 36px;
    border: 1px solid var(--border-color);
    font-size: 1.2rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-color);
    color: var(--text-primary);
    transition: var(--transition-fast);
  }
  .quick-size-btn:hover {
    border-color: var(--text-primary);
    background-color: var(--text-primary);
    color: var(--accent-inverse);
  }
  .quick-size-btn.disabled {
    text-decoration: line-through;
    color: var(--text-muted);
    cursor: not-allowed;
    border-color: var(--border-color) !important;
    background-color: transparent !important;
  }
  .quick-add-close {
    position: absolute;
    top: 4px;
    right: 8px;
    font-size: 1.8rem;
    color: var(--text-muted);
  }
</style>

<script>
  // Wishlist localStorage toggle script
  function toggleWishlistItem(id, btn) {
    let list = localStorage.getItem('user_wishlist');
    list = list ? JSON.parse(list) : [];

    const index = list.indexOf(id);
    if (index > -1) {
      list.splice(index, 1);
      btn.classList.remove('active');
      btn.querySelector('svg').style.fill = 'none';
    } else {
      list.push(id);
      btn.classList.add('active');
      btn.querySelector('svg').style.fill = 'var(--highlight-color)';
    }
    localStorage.setItem('user_wishlist', JSON.stringify(list));
  }

  // Set initial heart button state on load
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.js-wishlist-toggle').forEach(btn => {
      const card = btn.closest('.product-card');
      if (!card) return;
      const id = card.getAttribute('data-product-id');
      
      let list = localStorage.getItem('user_wishlist');
      list = list ? JSON.parse(list) : [];
      if (list.includes(id)) {
        btn.classList.add('active');
        btn.querySelector('svg').style.fill = 'var(--highlight-color)';
      }
    });
  });

  function toggleQuickAddBox(e, btn) {
    e.stopPropagation();
    const box = btn.nextElementSibling;
    if (box) box.classList.add('active');
  }

  function closeQuickAddBox(e, btn) {
    e.stopPropagation();
    const box = btn.closest('.quick-add-sizes-box');
    if (box) box.classList.remove('active');
  }

  // AJAX add variant to cart
  function addVariantToCartAjax(variantId, btn) {
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner" style="width:12px; height:12px; border-width:1.5px;"></span>';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        items: [{
          id: variantId,
          quantity: 1
        }]
      })
    })
    .then(response => response.json())
    .then(data => {
      btn.disabled = false;
      btn.textContent = originalText;
      // Close size selection box
      const box = btn.closest('.quick-add-sizes-box');
      if (box) box.classList.remove('active');
      // Open AJAX cart drawer
      if (window.openCartDrawer) window.openCartDrawer();
    })
    .catch(err => {
      console.error('Error adding variant:', err);
      btn.disabled = false;
      btn.textContent = originalText;
    });
  }
</script>
