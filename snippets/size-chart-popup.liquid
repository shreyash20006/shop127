{% comment %}
   Escape Clothing - Sizing Chart Popup Modal
{% endcomment %}

<div id="SizeGuideModal" class="size-guide-modal-overlay flex align-center justify-center">
  <div class="size-guide-modal-inner">
    <div class="modal-header flex justify-between align-center" style="margin-bottom: 24px;">
      <h3 style="font-family: var(--font-heading); font-size: 2.8rem; letter-spacing: 1px;">SIZE GUIDE & MEASUREMENTS</h3>
      <button id="SizeGuideClose" class="modal-close-btn">&times;</button>
    </div>

    <div style="overflow-x: auto; margin-bottom: 24px;">
      <table class="size-guide-modal-table" style="width: 100%; border-collapse: collapse; text-align: left; font-size: 1.4rem;">
        <thead>
          <tr style="border-bottom: 2px solid var(--border-color); color: var(--text-primary); font-weight: 700;">
            <th style="padding: 10px 4px;">SIZE</th>
            <th style="padding: 10px 4px;">CHEST (IN)</th>
            <th style="padding: 10px 4px;">LENGTH (IN)</th>
            <th style="padding: 10px 4px;">SHOULDER (IN)</th>
          </tr>
        </thead>
        <tbody style="color: var(--text-secondary);">
          <tr style="border-bottom: 1px solid var(--border-color);">
            <td style="padding: 12px 4px; font-weight: 700; color: #FFFFFF;">XS</td>
            <td style="padding: 12px 4px;">42</td>
            <td style="padding: 12px 4px;">27</td>
            <td style="padding: 12px 4px;">19.5</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--border-color);">
            <td style="padding: 12px 4px; font-weight: 700; color: #FFFFFF;">S</td>
            <td style="padding: 12px 4px;">44</td>
            <td style="padding: 12px 4px;">28</td>
            <td style="padding: 12px 4px;">20</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--border-color);">
            <td style="padding: 12px 4px; font-weight: 700; color: #FFFFFF;">M</td>
            <td style="padding: 12px 4px;">46</td>
            <td style="padding: 12px 4px;">29</td>
            <td style="padding: 12px 4px;">20.5</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--border-color);">
            <td style="padding: 12px 4px; font-weight: 700; color: #FFFFFF;">L</td>
            <td style="padding: 12px 4px;">48</td>
            <td style="padding: 12px 4px;">30</td>
            <td style="padding: 12px 4px;">21</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--border-color);">
            <td style="padding: 12px 4px; font-weight: 700; color: #FFFFFF;">XL</td>
            <td style="padding: 12px 4px;">50</td>
            <td style="padding: 12px 4px;">31</td>
            <td style="padding: 12px 4px;">21.5</td>
          </tr>
          <tr style="border-bottom: 1px solid var(--border-color);">
            <td style="padding: 12px 4px; font-weight: 700; color: #FFFFFF;">XXL</td>
            <td style="padding: 12px 4px;">52</td>
            <td style="padding: 12px 4px;">32</td>
            <td style="padding: 12px 4px;">22</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div style="border-top: 1px solid var(--border-color); padding-top: 16px; font-size: 1.2rem; color: var(--text-muted); line-height: 1.6;">
      <p><strong>Note:</strong> All our apparel is cut for a modern boxy, oversized streetwear look. Pick your standard sizes for signature volume, or size down one size for a regular look.</p>
    </div>
  </div>
</div>

<style>
  .size-guide-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(10, 10, 10, 0.95);
    z-index: 10005;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .size-guide-modal-overlay.active {
    opacity: 1;
    pointer-events: all;
  }
  .size-guide-modal-inner {
    width: 90%;
    max-width: 500px;
    background-color: var(--surface-primary);
    border: 1px solid var(--border-color);
    padding: 32px;
    border-radius: var(--border-radius);
    position: relative;
  }
  .modal-close-btn {
    font-size: 3.2rem;
    color: var(--text-muted);
  }
</style>
