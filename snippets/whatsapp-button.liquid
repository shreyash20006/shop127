{% comment %}
   Escape Clothing - Floating WhatsApp Button (Redesigned with Tailwind CSS)
{% endcomment %}

<a class="fixed bottom-8 right-8 z-[100] group" 
   href="https://wa.me/{{ settings.social_whatsapp_phone | replace: '+', '' | replace: ' ', '' | default: '918261094774' }}?text={{ settings.social_whatsapp_message | default: 'Hi! I want to order from Escape Clothing 👣' | url_encode }}" 
   target="_blank"
   aria-label="Chat on WhatsApp">
  <div class="relative w-16 h-16 flex items-center justify-center bg-[#25D366] text-white rounded-full shadow-lg hover:scale-110 transition-transform duration-300">
    <div class="absolute inset-0 bg-[#25D366] rounded-full blur-xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
